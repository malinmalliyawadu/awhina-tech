  }

  .wordmark {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.022em;
  }

  .wordmark-italic {
    font-style: italic;
    opacity: 0.55;
  }

  .email {
    text-decoration: none;
  }

  .email:hover {
    color: var(--pounamu);
  }

  @media (max-width: 640px) {
    .masthead {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
