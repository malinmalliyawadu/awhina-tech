---
const navLinks = [
  { href: "#work", label: "Work" },
  { href: "#about", label: "About" },
  { href: "#pricing", label: "Pricing" },
  { href: "#contact", label: "Contact" },
];
---

<header class="masthead">
  <div class="inner">
    <a href="/" class="brand" aria-label="Āwhina Tech home">
      <span class="brand-mark" aria-hidden="true">
        <!-- Lucide: heart-handshake -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
          <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
          <path d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08c.82.82 2.13.85 3 .07l2.07-1.9a2.82 2.82 0 0 1 3.79 0l2.96 2.66"/>
          <path d="m18 15-2-2"/>
          <path d="m15 18-2-2"/>
        </svg>
      </span>
      <span class="brand-word">Āwhina Tech</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="cta">
      <button type="button" class="theme-toggle" aria-label="Switch to dark theme">
        <!-- Lucide: moon -->
        <svg class="i-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
        <!-- Lucide: sun -->
        <svg class="i-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
      </button>
      <span class="status">
        <span class="status-dot" aria-hidden="true"></span>
        Taking on 2 charities this quarter
      </span>
      <a href="#contact" class="btn btn-primary" data-cta-label="Get in touch">Get in touch</a>
    </div>
  </div>
</header>

<style>
  .masthead {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--header-bg);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--line);
  }

  .inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 14px var(--pad-x);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 32px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--ink);
    font-weight: 600;
    letter-spacing: -0.018em;
    font-size: 17px;
  }

  .brand-mark {
    display: inline-flex;
    width: 26px;
    height: 26px;
    align-items: center;
    justify-content: center;
    color: var(--pounamu);
  }

  .brand-mark svg {
    width: 22px;
    height: 22px;
  }


  .nav {
    justify-self: center;
    display: flex;
    gap: 28px;
    font-size: 14px;
  }

  .nav a {
    color: var(--ink-2);
    text-decoration: none;
    font-weight: 500;
    letter-spacing: -0.005em;
    transition: color 160ms ease;
  }

  .nav a:hover {
    color: var(--pounamu);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 16px;
  }

  /* Hidden until the inline theme script runs (sets data-theme). With JS
     off the button would be inert, and system dark still applies via CSS. */
  .theme-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--ink-2);
    cursor: pointer;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  :global(:root[data-theme]) .theme-toggle {
    display: inline-flex;
  }

  .theme-toggle:hover {
    color: var(--ink);
    border-color: var(--ink);
    background: var(--surface-2);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--pounamu);
    outline-offset: 2px;
  }

  .theme-toggle svg {
    width: 18px;
    height: 18px;
  }

  /* Show the icon for the action the click performs:
     moon in light mode (→ go dark), sun in dark mode (→ go light). */
  .i-sun {
    display: none;
  }

  :global(:root[data-theme="dark"]) .i-moon {
    display: none;
  }

  :global(:root[data-theme="dark"]) .i-sun {
    display: inline-flex;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--muted);
    font-weight: 500;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--pounamu);
    box-shadow: 0 0 0 4px rgba(47, 93, 58, 0.16);
  }

  @media (max-width: 1024px) {
    .nav {
      display: none;
    }
    .inner {
      grid-template-columns: auto 1fr auto;
    }
    .nav {
      display: none;
    }
  }

  @media (max-width: 720px) {
    .status {
      display: none;
    }
    .inner {
      grid-template-columns: 1fr auto;
      gap: 16px;
    }
  }
</style>

<script>
  // Theme toggle. The actual theme/persistence logic lives in the
  // no-flash inline script in Base.astro (window.__setTheme).
  const btn = document.querySelector<HTMLButtonElement>(".theme-toggle");
  const set = (window as any).__setTheme as ((t: string) => void) | undefined;
  const current = (window as any).__currentTheme as
    | (() => string)
    | undefined;

  function label() {
    if (!btn) return;
    const dark = current?.() === "dark";
    btn.setAttribute(
      "aria-label",
      dark ? "Switch to light theme" : "Switch to dark theme",
    );
  }

  btn?.addEventListener("click", () => {
    const next = current?.() === "dark" ? "light" : "dark";
    set?.(next);
  });

  window.addEventListener("themechange", label);
  label();
</script>
