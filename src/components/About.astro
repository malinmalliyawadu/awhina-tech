---
import FadeUp from "./FadeUp.astro";
---

<section id="about" class="about">
  <div class="inner">
    <FadeUp>
      <div class="header">
        <span class="eyebrow">Who builds this</span>
        <h2 class="title">
          Fifteen years of engineering leadership across some of Aotearoa's
          largest public and private organisations — now sized for one charity
          at a time.
        </h2>
      </div>
    </FadeUp>

    <div class="body">
      <FadeUp delay={80}>
        <div class="narrative">
          <p>
            A Wellington developer with fifteen years leading
            large New Zealand engineering teams: Trade Me, ANZ, Stats NZ,
            Kiwi Wealth, Open Polytechnic, PartsTrader. Government, bank,
            e-commerce, education, B2B platforms. The kind
            of systems that have to be right — payments, bookings, reporting
            all at massive scale.
          </p>
          <p>
            Charities deserve software built to the same standard. They
            rarely get it. The off-the-shelf market is priced for
            organisations with hundreds of staff, and the agencies who could
            build something custom quote like they're working for one. Āwhina
            is the in-between: a single experienced developer, working
            directly with the charity, at a price a charity can actually
            carry.
          </p>
          <p class="kicker">
            One developer, one flat fee, one charity at a time.
          </p>
        </div>
      </FadeUp>

      <FadeUp delay={160}>
        <aside class="card" aria-label="About the founder">
          <img
            class="portrait"
            src="/malin.webp"
            alt="Malin"
            width="384"
            height="384"
            loading="lazy"
            decoding="async"
          />
          <h3 class="name">Malin</h3>
          <span class="caption">Founder &middot; Wellington, NZ</span>
          <div class="socials">
            <a
              class="social"
              href="https://github.com/malinmalliyawadu"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Malin on GitHub"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.05-.02-2.06-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.09 1.85 1.24 1.85 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.96 0-1.32.47-2.39 1.24-3.23-.13-.3-.54-1.53.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.05.14 3 .4 2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.23 0 4.63-2.81 5.65-5.49 5.95.43.37.82 1.1.82 2.22 0 1.6-.02 2.89-.02 3.28 0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5Z"/>
              </svg>
            </a>
            <a
              class="social"
              href="https://www.linkedin.com/in/malin-malliya-wadu-94956522/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Malin on LinkedIn"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"/>
              </svg>
            </a>
          </div>
        </aside>
      </FadeUp>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
  }

  .inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 112px var(--pad-x);
  }

  .header {
    display: grid;
    gap: 12px;
    max-width: 880px;
    margin-bottom: 64px;
  }

  .title {
    font-size: clamp(30px, 3.8vw, 46px);
    line-height: 1.12;
    margin: 8px 0 0;
  }

  .body {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 64px;
    align-items: start;
  }

  .narrative {
    display: grid;
    gap: 20px;
    max-width: 60ch;
  }

  .narrative p {
    margin: 0;
    font-size: 17px;
    line-height: 1.65;
    color: var(--ink-2);
  }

  .narrative .kicker {
    color: var(--ink);
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 19px;
  }

  .card {
    background: var(--wash);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 36px;
    box-shadow: var(--shadow-soft);
    display: grid;
    gap: 12px;
    position: relative;
    max-width: 360px;
    justify-self: start;
    justify-items: center;
    text-align: center;
  }

  .portrait {
    width: 156px;
    height: 156px;
    border-radius: var(--radius-blob);
    object-fit: cover;
    background: var(--pounamu-soft);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
    margin-bottom: 8px;
    display: block;
  }

  .name {
    font-size: 24px;
    line-height: 1.2;
    margin: 0;
  }

  .caption {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 15px;
    letter-spacing: 0.01em;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 2px;
  }

  .caption::before {
    content: "";
    display: inline-block;
    width: 18px;
    height: 2px;
    border-radius: 2px;
    background: var(--clay);
    flex-shrink: 0;
  }

  .socials {
    display: flex;
    gap: 8px;
    margin-top: 6px;
  }

  .social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    color: var(--muted);
    background: transparent;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  .social:hover {
    color: var(--pounamu);
    border-color: var(--pounamu);
    background: var(--surface-2);
  }

  .social:focus-visible {
    outline: 2px solid var(--pounamu);
    outline-offset: 2px;
  }

  .social svg {
    display: block;
  }

  @media (max-width: 1024px) {
    .body {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .card {
      max-width: 360px;
    }
  }

  @media (max-width: 720px) {
    .inner {
      padding: 72px var(--pad-x);
    }
    .header {
      margin-bottom: 40px;
    }
    .card {
      padding: 28px;
    }
  }
</style>
