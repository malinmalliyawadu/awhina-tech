---
import FadeUp from "./FadeUp.astro";
---

<section id="about" class="about">
  <div class="inner">
    <FadeUp>
      <div class="header">
        <span class="eyebrow">Who builds this</span>
        <h2 class="title">
          Fifteen years of engineering leadership across some of Aotearoa's
          largest public and private organisations — now sized for one charity
          at a time.
        </h2>
      </div>
    </FadeUp>

    <div class="body">
      <FadeUp delay={80}>
        <div class="narrative">
          <p>
            A Wellington developer with fifteen years leading
            large New Zealand engineering teams: Trade Me, ANZ, Stats NZ,
            Kiwi Wealth, Open Polytechnic, PartsTrader. Govenment, bank,
            e-commerce, education, B2B platforms. The kind
            of systems that have to be right — payments, bookings, reporting
            all at massive scale.
          </p>
          <p>
            Charities deserve software built to the same standard. They
            rarely get it. The off-the-shelf market is priced for
            organisations with hundreds of staff, and the agencies who could
            build something custom quote like they're working for one. Āwhina
            is the in-between: a single experienced developer, working
            directly with the charity, at a price a charity can actually
            carry.
          </p>
          <p class="kicker">
            One developer, one flat fee, one charity at a time.
          </p>
        </div>
      </FadeUp>

      <FadeUp delay={160}>
        <aside class="card" aria-label="About the founder">
          <img
            class="portrait"
            src="/malin.webp"
            alt="Malin"
            width="384"
            height="384"
            loading="lazy"
            decoding="async"
          />
          <h3 class="name">Malin</h3>
          <span class="caption">Founder &middot; Wellington, NZ</span>
        </aside>
      </FadeUp>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
  }

  .inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 112px var(--pad-x);
  }

  .header {
    display: grid;
    gap: 12px;
    max-width: 880px;
    margin-bottom: 64px;
  }

  .title {
    font-size: clamp(32px, 4.2vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    font-weight: 500;
    margin: 8px 0 0;
  }

  .body {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: 64px;
    align-items: start;
  }

  .narrative {
    display: grid;
    gap: 20px;
    max-width: 60ch;
  }

  .narrative p {
    margin: 0;
    font-size: 17px;
    line-height: 1.65;
    color: var(--ink-2);
  }

  .narrative .kicker {
    color: var(--ink);
    font-weight: 500;
  }

  .card {
    background: linear-gradient(180deg, #f4f7f1 0%, #f9faf5 100%);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 36px;
    box-shadow: var(--shadow-soft);
    display: grid;
    gap: 12px;
    position: relative;
  }

  .portrait {
    width: 128px;
    height: 128px;
    border-radius: 18px;
    object-fit: cover;
    background: var(--pounamu-soft);
    border: 1px solid var(--line);
    box-shadow:
      0 1px 2px rgba(14, 20, 19, 0.06),
      0 8px 20px rgba(14, 20, 19, 0.08);
    margin-bottom: 8px;
    display: block;
  }

  .name {
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: -0.018em;
    font-weight: 600;
    margin: 0;
  }

  .caption {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 2px;
  }

  .caption::before {
    content: "";
    display: inline-block;
    width: 18px;
    height: 1px;
    background: var(--pounamu);
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .body {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .card {
      max-width: 480px;
    }
  }

  @media (max-width: 720px) {
    .inner {
      padding: 72px var(--pad-x);
    }
    .header {
      margin-bottom: 40px;
    }
    .card {
      padding: 28px;
    }
  }
</style>
