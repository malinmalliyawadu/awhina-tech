---
interface Props {
  src: string;
  alt: string;
  loading?: "eager" | "lazy";
}

const { src, alt, loading = "lazy" } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const cleaned = src.replace(/^\//, "");
const href = `${base}/${cleaned}`;
---

<img class="screenshot" src={href} alt={alt} loading={loading} decoding="async" />

<style>
  .screenshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }
</style>
