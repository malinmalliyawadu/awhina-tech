---
import { createHash } from "node:crypto";
import { readFileSync, statSync } from "node:fs";
import { fileURLToPath } from "node:url";

interface Props {
  src: string;
  alt: string;
  loading?: "eager" | "lazy";
}

const { src, alt, loading = "lazy" } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const cleaned = src.replace(/^\//, "");

const publicDir = fileURLToPath(new URL("../../public/", import.meta.url));
let version = "";
try {
  const filePath = publicDir + cleaned;
  statSync(filePath);
  version = createHash("sha1")
    .update(readFileSync(filePath))
    .digest("hex")
    .slice(0, 8);
} catch {
  // file not found at build time — fall back to no version, link still renders
}

const href = version
  ? `${base}/${cleaned}?v=${version}`
  : `${base}/${cleaned}`;
---

<img class="screenshot" src={href} alt={alt} loading={loading} decoding="async" />

<style>
  .screenshot {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }
</style>
