---
import FadeUp from "./FadeUp.astro";
---

<section id="contact" class="contact">
  <div class="inner">
    <div class="grid">
      <FadeUp>
        <div class="left">
          <span class="eyebrow">Get in touch</span>
          <h2 class="title">Tell us about the mahi.</h2>
          <p class="lede">
            We're a small team in Wellington. Write to us in your own words —
            no project brief, no pitch deck, no sales process. We'll write
            back, usually within a day, always within two.
          </p>

          <div class="signoff">
            <div class="signoff-line">— Awhina Tech</div>
            <div class="signoff-meta">Te Whanganui-a-Tara · Aotearoa</div>
          </div>

          <div class="contact-strip">
            <a href="mailto:kiaora@awhinatech.nz" class="cs-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M3 7l9 6 9-6M3 7v10h18V7M3 7l9-4 9 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              kiaora@awhinatech.nz
            </a>
            <a href="tel:+64212095657" class="cs-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M5 4h4l2 5-3 2a12 12 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A18 18 0 0 1 3 6a2 2 0 0 1 2-2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              021 209 5657
            </a>
          </div>
        </div>
      </FadeUp>

      <FadeUp delay={100}>
        <div class="letter-shell">
          <form class="letter" data-contact-form>
            <div class="letter-paper">
              <p class="letter-prose">
                Kia ora, my name is
                <span class="i-wrap" data-input>
                  <label for="contact-name" class="sr-only">Your name</label>
                  <span class="i-mirror" aria-hidden="true">your name</span>
                  <input
                    id="contact-name"
                    name="name"
                    required
                    autocomplete="name"
                    placeholder="your name"
                  />
                </span>
                and I help run
                <span class="i-wrap" data-input>
                  <label for="contact-charity" class="sr-only">Your charity</label>
                  <span class="i-mirror" aria-hidden="true">your charity</span>
                  <input
                    id="contact-charity"
                    name="charity"
                    autocomplete="organization"
                    placeholder="your charity"
                  />
                </span>.
                You can reach me at
                <span class="i-wrap" data-input>
                  <label for="contact-email" class="sr-only">Your email</label>
                  <span class="i-mirror" aria-hidden="true">you@charity.org.nz</span>
                  <input
                    id="contact-email"
                    name="email"
                    type="email"
                    required
                    autocomplete="email"
                    placeholder="you@charity.org.nz"
                  />
                </span>.
              </p>

              <div class="letter-message">
                <label for="contact-message" class="msg-label">Here's what we're thinking about</label>
                <textarea
                  id="contact-message"
                  name="message"
                  rows="3"
                  required
                  placeholder="A booking system that doesn't burn through volunteer hours, a website our donors can actually use, a way to send updates without paying for Mailchimp…"
                ></textarea>
              </div>
            </div>

            <div class="letter-actions">
              <button type="submit" class="btn btn-primary">
                Send it
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <span class="form-note">Usually a day. Always within two.</span>
            </div>
          </form>

          <div class="thanks" data-thanks hidden>
            <div class="thanks-mark" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M5 12l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="thanks-body-wrap">
              <h3 class="thanks-title" data-thanks-title>Thanks — got it.</h3>
              <p class="thanks-body">
                We'll be back in touch within two working days. If it's
                urgent, email us directly at
                <a href="mailto:kiaora@awhinatech.nz">kiaora@awhinatech.nz</a>.
              </p>
            </div>
          </div>
        </div>
      </FadeUp>
    </div>
  </div>

  <footer class="footer">
    <div class="footer-inner">
      <div class="foot-brand">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
            <path d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08c.82.82 2.13.85 3 .07l2.07-1.9a2.82 2.82 0 0 1 3.79 0l2.96 2.66"/>
            <path d="m18 15-2-2"/>
            <path d="m15 18-2-2"/>
          </svg>
        </span>
        <span class="foot-word">Awhina Tech</span>
      </div>
      <div class="foot-meta">
        Aotearoa New Zealand · Mahi tahi tātou — let's work together
      </div>
      <div class="foot-copy">© {new Date().getFullYear()} Awhina Tech</div>
    </div>
  </footer>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const thanks = document.querySelector<HTMLElement>("[data-thanks]");
  const thanksTitle = document.querySelector<HTMLElement>("[data-thanks-title]");

  // Mirror-width inline inputs: the hidden mirror span sets the wrap width,
  // the input is absolutely positioned to fill it.
  document.querySelectorAll<HTMLElement>("[data-input]").forEach((wrap) => {
    const input = wrap.querySelector<HTMLInputElement>("input");
    const mirror = wrap.querySelector<HTMLElement>(".i-mirror");
    if (!input || !mirror) return;
    const sync = () => {
      mirror.textContent = input.value || input.placeholder || "";
    };
    input.addEventListener("input", sync);
    sync();
  });

  // Auto-grow textarea
  const textarea = form?.querySelector<HTMLTextAreaElement>("textarea");
  const autosize = () => {
    if (!textarea) return;
    textarea.style.height = "auto";
    textarea.style.height = textarea.scrollHeight + "px";
  };
  textarea?.addEventListener("input", autosize);
  requestAnimationFrame(autosize);

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    if (!form || !thanks) return;
    const nameInput = form.elements.namedItem("name") as HTMLInputElement | null;
    const firstName = nameInput?.value?.trim().split(/\s+/)[0];
    if (thanksTitle) {
      thanksTitle.textContent = firstName
        ? `Thanks, ${firstName} — got it.`
        : "Thanks — got it.";
    }
    form.hidden = true;
    thanks.hidden = false;
  });
</script>

<style>
  .contact {
    background: var(--surface);
  }

  .inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 112px var(--pad-x) 80px;
  }

  .grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 80px;
    align-items: start;
  }

  /* LEFT — signed note */
  .left { padding-top: 4px; }

  .title {
    font-size: clamp(34px, 4.4vw, 56px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-weight: 500;
    margin: 14px 0 18px;
    text-wrap: balance;
  }

  .lede {
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 30px;
    max-width: 38ch;
  }

  .signoff {
    border-left: 2px solid var(--pounamu);
    padding: 2px 0 2px 14px;
    margin-bottom: 28px;
  }

  .signoff-line {
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
  }

  .signoff-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-top: 4px;
  }

  .contact-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
    padding-top: 22px;
    border-top: 1px solid var(--line);
  }

  .cs-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--ink);
    text-decoration: none;
    transition: color 160ms ease;
  }

  .cs-link svg {
    color: var(--muted);
    transition: color 160ms ease;
  }

  .cs-link:hover { color: var(--pounamu); }
  .cs-link:hover svg { color: var(--pounamu); }

  /* RIGHT — letter */
  .letter-shell {
    position: relative;
  }

  .letter-paper {
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 38px 38px 32px;
    box-shadow: var(--shadow-soft);
  }

  .letter-prose {
    margin: 0;
    font-size: 19px;
    line-height: 1.85;
    color: var(--ink-2);
    letter-spacing: -0.005em;
  }

  /* Inline expanding input */
  .i-wrap {
    position: relative;
    display: inline-block;
    vertical-align: baseline;
    min-width: 5ch;
    padding: 0 3px;
  }

  .i-wrap::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 6px;
    height: 1.5px;
    background: rgba(14, 20, 19, 0.2);
    transition: background-color 200ms ease, height 200ms ease;
    pointer-events: none;
  }

  .i-wrap:hover::before {
    background: rgba(14, 20, 19, 0.45);
  }

  .i-wrap:focus-within::before {
    background: var(--pounamu);
    height: 2px;
  }

  .i-mirror {
    visibility: hidden;
    white-space: pre;
    display: inline-block;
    font: inherit;
    letter-spacing: inherit;
  }

  .i-wrap input {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background: transparent;
    border: 0;
    padding: 0 3px;
    font: inherit;
    color: var(--ink);
    outline: none;
    letter-spacing: inherit;
  }

  .i-wrap input::placeholder {
    color: rgba(14, 20, 19, 0.32);
  }

  /* Message — separate block, but on the same paper */
  .letter-message {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px dashed var(--line);
  }

  .msg-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .letter-message textarea {
    width: 100%;
    background: transparent;
    border: 0;
    padding: 0;
    font-family: inherit;
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink);
    outline: none;
    resize: none;
    min-height: 76px;
    letter-spacing: -0.005em;
    overflow: hidden;
  }

  .letter-message textarea::placeholder {
    color: rgba(14, 20, 19, 0.32);
  }

  .letter-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 22px;
    flex-wrap: wrap;
  }

  .form-note {
    font-size: 12px;
    color: var(--muted);
  }

  /* Thanks state replaces the form on submit */
  [hidden] { display: none !important; }

  .thanks {
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 40px 38px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px;
    align-items: start;
    box-shadow: var(--shadow-soft);
  }

  .thanks-mark {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--pounamu-soft);
    color: var(--pounamu);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .thanks-title {
    margin: 4px 0 8px;
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .thanks-body {
    margin: 0;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 48ch;
  }

  .thanks-body a {
    color: var(--pounamu);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* FOOTER */
  .footer {
    border-top: 1px solid var(--line);
    background: var(--surface);
  }

  .footer-inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 28px var(--pad-x);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 24px;
    align-items: center;
  }

  .foot-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.018em;
  }

  .brand-mark {
    display: inline-flex;
    width: 22px;
    height: 22px;
    color: var(--pounamu);
    align-items: center;
    justify-content: center;
  }
  .brand-mark svg { width: 18px; height: 18px; }

  .foot-meta {
    justify-self: center;
    font-size: 12px;
    color: var(--muted);
  }

  .foot-copy {
    font-size: 12px;
    color: var(--muted);
  }

  @media (max-width: 1024px) {
    .grid { grid-template-columns: 1fr; gap: 56px; }
  }

  @media (max-width: 720px) {
    .inner { padding: 72px var(--pad-x) 56px; }
    .letter-paper { padding: 28px 22px; }
    .letter-prose { font-size: 17px; line-height: 1.8; }
    .letter-message textarea { font-size: 16px; }
    .thanks { padding: 32px 24px; }
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 8px;
      text-align: left;
    }
    .foot-meta { justify-self: start; }
  }
</style>
