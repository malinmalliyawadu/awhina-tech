---
import FadeUp from "./FadeUp.astro";
import MockCharitySite from "./MockCharitySite.astro";
---

<section class="hero">
  <div class="grid">
    <FadeUp>
      <div class="kicker mono">⏤ A quiet proposition for charities</div>
      <h1 class="headline serif">
        Software that<br />
        <span class="italic">doesn't take</span><br />
        from the work.
      </h1>
      <div class="subhead">
        <p>
          We build custom websites and apps for Aotearoa's charities — the kind
          big SaaS vendors charge thousands for, and don't even build well.
        </p>
        <p>
          One flat fee. Hosting and ongoing support included. No per-donor
          pricing, no contact-list tax, no executive compensation hidden in the
          invoice.
        </p>
      </div>
    </FadeUp>

    <FadeUp delay={150}>
      <div class="mock-wrap">
        <div class="mock-frame">
          <MockCharitySite scheme="warm" />
        </div>
        <div class="mono caption">FIG. 01 — A booking & roster site for Everybody Eats</div>
      </div>
    </FadeUp>
  </div>

  <div class="footer-row">
    <a href="#contact" class="serif email-link">Email us →</a>
    <span class="mono helper">or scroll to read the case</span>
    <span class="spacer"></span>
    <span class="mono helper">NZD $50 / month · all-in</span>
  </div>
</section>

<style>
  .hero {
    padding: 80px var(--pad-x) 64px;
    border-bottom: 1px solid var(--ink);
  }

  .grid {
    display: grid;
    grid-template-columns: 5fr 4fr;
    gap: 64px;
    align-items: end;
  }

  .kicker {
    margin-bottom: 32px;
    color: var(--pounamu);
  }

  .headline {
    font-family: var(--font-serif);
    font-size: 104px;
    line-height: 0.95;
    margin: 0 0 32px;
    letter-spacing: -0.022em;
  }

  .italic {
    font-style: italic;
  }

  .subhead {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    max-width: 720px;
  }

  .subhead p {
    font-size: 16px;
    line-height: 1.55;
    margin: 0;
    opacity: 0.78;
  }

  .mock-wrap {
    position: relative;
  }

  .mock-frame {
    aspect-ratio: 4 / 5;
    background: #fff;
    border: 1px solid var(--ink);
    box-shadow: 8px 8px 0 var(--ink);
    overflow: hidden;
  }

  .caption {
    margin-top: 12px;
    font-size: 10px;
    opacity: 0.6;
    text-align: right;
  }

  .footer-row {
    display: flex;
    gap: 24px;
    align-items: baseline;
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--ink);
    flex-wrap: wrap;
  }

  .email-link {
    font-size: 32px;
    text-decoration: none;
    font-style: italic;
    color: var(--ink);
  }

  .email-link:hover {
    opacity: 0.85;
  }

  .helper {
    opacity: 0.5;
  }

  .spacer {
    flex: 1;
  }

  @media (max-width: 960px) {
    .hero {
      padding: 64px var(--pad-x) 48px;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .headline {
      font-size: 72px;
    }
  }

  @media (max-width: 640px) {
    .headline {
      font-size: 52px;
    }

    .subhead {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .email-link {
      font-size: 24px;
    }

    .footer-row {
      gap: 12px;
    }
  }
</style>
