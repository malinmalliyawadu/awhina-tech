---
import FadeUp from "./FadeUp.astro";
import MockCharitySite from "./MockCharitySite.astro";

const stats = [
  { v: "$50", l: "NZD / month, all-in" },
  { v: "3", l: "charities served" },
  { v: "0", l: "per-donor fees" },
];
---

<section class="hero">
  <div class="inner">
    <FadeUp>
      <span class="eyebrow">Custom software for Aotearoa charities</span>
    </FadeUp>

    <FadeUp delay={60}>
      <h1 class="headline">
        Software that doesn't take<br />
        <span class="accent">from the work.</span>
      </h1>
    </FadeUp>

    <FadeUp delay={120}>
      <div class="lede-row">
        <p class="lede">
          We build custom websites and apps for Aotearoa's charities — the kind big
          SaaS vendors charge thousands for, and don't even build well. One flat
          fee. Hosting and ongoing support included.
        </p>
        <div class="cta-row">
          <a href="#contact" class="btn btn-primary">
            Start a conversation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#work" class="btn btn-ghost">See the work</a>
        </div>
      </div>
    </FadeUp>

    <FadeUp delay={200}>
      <div class="showcase">
        <div class="window">
          <div class="window-bar">
            <div class="dots">
              <span></span><span></span><span></span>
            </div>
            <div class="window-url">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M8 11V7a4 4 0 1 1 8 0v4M5 11h14v9H5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              everybodyeats.nz
            </div>
            <div class="window-meta">Live · NZ-hosted</div>
          </div>
          <div class="window-frame">
            <MockCharitySite scheme="warm" />
          </div>
        </div>
      </div>
    </FadeUp>

    <FadeUp delay={260}>
      <dl class="stats">
        {stats.map((s) => (
          <div class="stat">
            <dt class="stat-v">{s.v}</dt>
            <dd class="stat-l">{s.l}</dd>
          </div>
        ))}
        <div class="stat trust">
          <dt class="stat-l muted">Trusted by</dt>
          <dd class="stat-orgs">Everybody Eats · Fair Food NZ · Compassion</dd>
        </div>
      </dl>
    </FadeUp>
  </div>
</section>

<style>
  .hero {
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(60% 80% at 50% 0%, rgba(47, 93, 58, 0.05), transparent 70%),
      var(--surface);
  }

  .inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 96px var(--pad-x) 80px;
  }

  .headline {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(48px, 7.4vw, 96px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    margin: 24px 0 0;
    max-width: 17ch;
  }

  .accent {
    color: var(--pounamu);
  }

  .lede-row {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    margin-top: 40px;
    align-items: end;
  }

  .lede {
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 56ch;
  }

  .cta-row {
    display: inline-flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-self: end;
  }

  .showcase {
    margin-top: 64px;
    position: relative;
  }

  .window {
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(14, 20, 19, 0.04),
      0 24px 60px -20px rgba(14, 20, 19, 0.18);
  }

  .window-bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
    padding: 12px 16px;
    background: var(--surface-2);
    border-bottom: 1px solid var(--line);
    font-size: 12px;
    color: var(--muted);
  }

  .dots {
    display: inline-flex;
    gap: 6px;
  }

  .dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--line);
  }

  .window-url {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    justify-self: center;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .window-meta {
    font-size: 11px;
    color: var(--pounamu);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .window-meta::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--pounamu);
    box-shadow: 0 0 0 3px rgba(47, 93, 58, 0.18);
  }

  .window-frame {
    aspect-ratio: 16 / 9;
    background: #fff;
  }

  .stats {
    margin: 56px 0 0;
    padding: 24px 0 0;
    border-top: 1px solid var(--line);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-v {
    font-size: 32px;
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1;
    margin: 0;
  }

  .stat-l {
    font-size: 12px;
    color: var(--muted);
    margin: 0;
    letter-spacing: -0.005em;
  }

  .stat.trust {
    grid-column: span 1;
  }

  .stat.trust .stat-orgs {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-2);
    margin: 0;
    line-height: 1.4;
  }

  @media (max-width: 1024px) {
    .inner { padding: 72px var(--pad-x) 64px; }
    .lede-row {
      grid-template-columns: 1fr;
      gap: 28px;
      align-items: start;
    }
    .cta-row { justify-self: start; }
    .stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 720px) {
    .inner { padding: 48px var(--pad-x) 48px; }
    .headline { letter-spacing: -0.03em; }
    .window-meta { display: none; }
    .stats {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
