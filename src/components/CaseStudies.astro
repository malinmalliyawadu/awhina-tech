---
import FadeUp from "./FadeUp.astro";
import Screenshot from "./Screenshot.astro";
import { CASES } from "../data/cases";
---

<section id="work" class="cases">
  <div class="inner">
    <FadeUp>
      <div class="header">
        <span class="eyebrow">The work</span>
        <h2 class="title">
          Three charities. Three custom builds. Same flat fee.
        </h2>
        <p class="lede">
          Each of these replaced a tangle of SaaS subscriptions with a single
          purpose-built site. Hosted, supported, and built around how the
          charity actually works — not how a CRM thinks it should.
        </p>
      </div>
    </FadeUp>

    <div class="stack">
      {
        CASES.map((c, i) => {
          const imageRight = i % 2 === 0;
          return (
            <FadeUp delay={i * 80}>
              <article
                class:list={["case", imageRight ? "image-right" : "image-left"]}
                data-scheme={c.scheme}
              >
                <div class="text">
                  <div class="case-meta">
                    <span class="case-num">0{i + 1}</span>
                    <span class="case-kicker">{c.kicker}</span>
                  </div>
                  <h3 class="name">{c.name}</h3>
                  <p class="blurb">{c.blurb}</p>
                  <div class="metrics">
                    {c.metrics.map((m) => (
                      <div class="metric">
                        <div class="metric-v">{m.v}</div>
                        <div class="metric-l">{m.l}</div>
                      </div>
                    ))}
                  </div>
                  <a class="case-link" href="#contact">
                    Talk about a build like this
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                </div>
                <div class="image">
                  <div class="image-frame">
                    <Screenshot src={c.image} alt={c.imageAlt} />
                  </div>
                </div>
              </article>
            </FadeUp>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .cases {
    border-bottom: 1px solid var(--line);
    background: var(--surface);
  }

  .inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 112px var(--pad-x);
  }

  .header {
    display: grid;
    gap: 12px;
    max-width: 720px;
    margin-bottom: 72px;
  }

  .title {
    font-size: clamp(32px, 4.2vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    font-weight: 500;
    margin: 8px 0 0;
  }

  .lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--muted);
    margin: 8px 0 0;
    max-width: 60ch;
  }

  .stack {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .case {
    display: grid;
    gap: 56px;
    align-items: center;
    padding: 56px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    background: var(--surface-2);
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  .case:hover {
    border-color: rgba(14, 20, 19, 0.18);
    box-shadow: var(--shadow-card);
  }

  .case[data-scheme="warm"] {
    background: linear-gradient(180deg, #fbf6ee 0%, #fdfaf3 100%);
  }
  .case[data-scheme="forest"] {
    background: linear-gradient(180deg, #f1f4ec 0%, #f7f9f3 100%);
  }
  .case[data-scheme="sea"] {
    background: linear-gradient(180deg, #eef2f1 0%, #f4f7f6 100%);
  }

  .case.image-right {
    grid-template-columns: 5fr 6fr;
  }
  .case.image-left {
    grid-template-columns: 6fr 5fr;
  }
  .case.image-left .text { order: 2; }
  .case.image-left .image { order: 1; }

  .case-meta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .case-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.06em;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 3px 7px;
  }

  .case-kicker {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .name {
    font-size: clamp(36px, 4vw, 52px);
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 500;
    margin: 0 0 20px;
  }

  .blurb {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 28px;
    max-width: 50ch;
  }

  .metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding-top: 24px;
    border-top: 1px solid rgba(14, 20, 19, 0.08);
    margin-bottom: 28px;
  }

  .metric-v {
    font-size: 26px;
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 500;
    margin-bottom: 6px;
  }

  .metric-l {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.4;
  }

  .case-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--ink);
    text-decoration: none;
    font-weight: 500;
    font-size: 14px;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: color 160ms ease;
  }

  .case-link:hover {
    color: var(--pounamu);
  }

  .image-frame {
    aspect-ratio: 4 / 3;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(14, 20, 19, 0.05),
      0 20px 40px -20px rgba(14, 20, 19, 0.18);
  }

  @media (max-width: 1024px) {
    .case {
      padding: 40px;
      gap: 40px;
    }
    .case,
    .case.image-right,
    .case.image-left {
      grid-template-columns: 1fr;
    }
    .case.image-left .text,
    .case.image-left .image { order: initial; }
  }

  @media (max-width: 720px) {
    .inner { padding: 72px var(--pad-x); }
    .case { padding: 28px; gap: 28px; }
    .metrics { grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .metric-v { font-size: 22px; }
  }
</style>
