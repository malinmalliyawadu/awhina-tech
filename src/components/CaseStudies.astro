---
import FadeUp from "./FadeUp.astro";
import Screenshot from "./Screenshot.astro";
import { CASES } from "../data/cases";

const splitItalic = (name: string) => {
  const parts = name.split(" ");
  return parts.map((w, j) => ({ word: w, italic: j === parts.length - 1 }));
};
---

<section class="cases">
  <FadeUp>
    <div class="header">
      <div class="mono">§ II. The work</div>
      <h2 class="title serif">
        Three charities. Three custom builds. Same monthly fee as a phone plan.
      </h2>
    </div>
  </FadeUp>

  <div class="stack">
    {
      CASES.map((c, i) => {
        const imageRight = i % 2 === 0;
        const words = splitItalic(c.name);
        return (
          <FadeUp delay={i * 60}>
            <article class:list={["case", imageRight ? "image-right" : "image-left"]}>
              <div class="text">
                <div class="mono kicker">FIG. 0{i + 2} · {c.kicker}</div>
                <h3 class="name serif">
                  {words.map((w, j) => (
                    <span class:list={[w.italic && "italic"]}>
                      {w.word}{j < words.length - 1 ? " " : ""}
                    </span>
                  ))}
                </h3>
                <p class="blurb">{c.blurb}</p>
                <div class="metrics">
                  {c.metrics.map((m) => (
                    <div class="metric">
                      <div class="metric-v serif">{m.v}</div>
                      <div class="metric-l mono">{m.l}</div>
                    </div>
                  ))}
                </div>
              </div>
              <div class="image">
                <div class="image-frame">
                  <Screenshot src={c.image} alt={c.imageAlt} />
                </div>
              </div>
            </article>
          </FadeUp>
        );
      })
    }
  </div>
</section>

<style>
  .cases {
    padding: 96px var(--pad-x);
    border-bottom: 1px solid var(--ink);
  }

  .header {
    display: grid;
    grid-template-columns: 1fr 3fr;
    gap: 64px;
    margin-bottom: 56px;
  }

  .title {
    font-size: 56px;
    line-height: 1.05;
    margin: 0;
  }

  .stack {
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .case {
    display: grid;
    gap: 64px;
    align-items: center;
    padding-top: 48px;
    border-top: 1px solid var(--ink);
  }

  .case.image-right {
    grid-template-columns: 5fr 4fr;
  }

  .case.image-left {
    grid-template-columns: 4fr 5fr;
  }

  .case.image-left .text {
    order: 2;
  }

  .case.image-left .image {
    order: 1;
  }

  .kicker {
    margin-bottom: 16px;
  }

  .name {
    font-size: 64px;
    line-height: 0.95;
    margin: 0 0 24px;
    font-weight: 400;
    letter-spacing: -0.022em;
  }

  .italic {
    font-style: italic;
  }

  .blurb {
    font-size: 17px;
    line-height: 1.55;
    opacity: 0.78;
    margin: 0 0 32px;
    max-width: 460px;
  }

  .metrics {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--ink);
  }

  .metric-v {
    font-size: 32px;
    line-height: 1;
    margin-bottom: 6px;
  }

  .metric-l {
    font-size: 9px;
    opacity: 0.6;
  }

  .image-frame {
    aspect-ratio: 5 / 4;
    background: #fff;
    border: 1px solid var(--ink);
    overflow: hidden;
  }

  @media (max-width: 960px) {
    .cases {
      padding: 72px var(--pad-x);
    }

    .header {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-bottom: 40px;
    }

    .title {
      font-size: 40px;
    }

    .case,
    .case.image-right,
    .case.image-left {
      grid-template-columns: 1fr;
      gap: 32px;
      padding-top: 32px;
    }

    .case.image-left .text,
    .case.image-left .image {
      order: initial;
    }

    .name {
      font-size: 48px;
    }
  }

  @media (max-width: 640px) {
    .title {
      font-size: 32px;
    }

    .name {
      font-size: 40px;
    }

    .blurb {
      font-size: 15px;
    }

    .metric-v {
      font-size: 24px;
    }
  }
</style>
