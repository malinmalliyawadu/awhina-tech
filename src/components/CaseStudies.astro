---
import FadeUp from "./FadeUp.astro";
import Screenshot from "./Screenshot.astro";
import { CASES } from "../data/cases";
---

<section id="work" class="cases">
  <div class="inner">
    <FadeUp>
      <div class="header">
        <span class="eyebrow">The work</span>
        <h2 class="title">
          Three charities. Three custom builds. Same flat fee.
        </h2>
        <p class="lede">
          Each of these replaced a tangle of SaaS subscriptions with a single
          purpose-built site. Hosted, supported, and built around how the
          charity actually works — not how a CRM thinks it should.
        </p>
      </div>
    </FadeUp>

    <div class="stack">
      {
        CASES.map((c, i) => {
          const imageRight = i % 2 === 0;
          return (
            <FadeUp delay={i * 80}>
              <article
                class:list={["case", imageRight ? "image-right" : "image-left"]}
                data-scheme={c.scheme}
              >
                <div class="text">
                  <div class="case-meta">
                    <span class="case-num">0{i + 1}</span>
                    <span class="case-kicker">{c.kicker}</span>
                  </div>
                  <h3 class="name">{c.name}</h3>
                  <p class="blurb">{c.blurb}</p>
                  {c.metrics.length > 0 && (
                    <div class="metrics">
                      {c.metrics.map((m) => (
                        <div class="metric">
                          <div class="metric-v">{m.v}</div>
                          <div class="metric-l">{m.l}</div>
                        </div>
                      ))}
                    </div>
                  )}
                  <a
                    class="case-link"
                    href="#contact"
                    data-prefill={`We saw your work with ${c.name} and we're after something similar — keen to talk through what we've got in mind.`}
                    data-case-name={c.name}
                  >
                    Talk about a build like this
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                </div>
                <div class="image">
                  <div
                    class:list={[
                      "image-frame",
                      c.phoneImage && !c.beforeImage && "has-phone",
                      c.beforeImage && "compare",
                    ]}
                  >
                    {c.beforeImage ? (
                      <div class="compare-stack">
                        <div class="compare-layer">
                          <Screenshot src={c.image} alt={c.imageAlt} />
                          {c.phoneImage && (
                            <div class="phone-overlay" aria-hidden="false">
                              <div class="phone-frame">
                                <Screenshot
                                  src={c.phoneImage}
                                  alt={c.phoneImageAlt ?? ""}
                                />
                              </div>
                            </div>
                          )}
                        </div>
                        <div class="compare-layer compare-before">
                          <Screenshot
                            src={c.beforeImage}
                            alt={c.beforeImageAlt ?? ""}
                          />
                        </div>
                        <input
                          class="compare-range"
                          type="range"
                          min="0"
                          max="100"
                          value="10"
                          autocomplete="off"
                          aria-label={`Drag to compare ${c.name}'s old volunteer site with the rebuilt one`}
                        />
                        <div class="compare-divider" aria-hidden="true">
                          <span class="compare-grip">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                              <path d="M9 6l-5 6 5 6M15 6l5 6-5 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          </span>
                        </div>
                        <span class="compare-label compare-label-before" aria-hidden="true">Before</span>
                        <span class="compare-label compare-label-after" aria-hidden="true">After</span>
                      </div>
                    ) : (
                      <Screenshot src={c.image} alt={c.imageAlt} />
                    )}
                    {c.phoneImage && !c.beforeImage && (
                      <div class="phone-overlay" aria-hidden="false">
                        <div class="phone-frame">
                          <Screenshot
                            src={c.phoneImage}
                            alt={c.phoneImageAlt ?? ""}
                          />
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              </article>
            </FadeUp>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .cases {
    border-bottom: 1px solid var(--line);
    background: var(--surface);
  }

  .inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 112px var(--pad-x);
  }

  .header {
    display: grid;
    gap: 12px;
    max-width: 720px;
    margin-bottom: 72px;
  }

  .title {
    font-size: clamp(32px, 4.2vw, 52px);
    line-height: 1.08;
    margin: 8px 0 0;
  }

  .lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--muted);
    margin: 8px 0 0;
    max-width: 60ch;
  }

  .stack {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .case {
    display: grid;
    gap: 56px;
    align-items: center;
    padding: 56px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    background: var(--surface-2);
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  .case:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-card);
  }

  .case[data-scheme="warm"] {
    background: var(--tint-warm);
  }
  .case[data-scheme="forest"] {
    background: var(--tint-forest);
  }
  .case[data-scheme="sea"] {
    background: var(--tint-sea);
  }

  .case.image-right {
    grid-template-columns: 5fr 6fr;
  }
  .case.image-left {
    grid-template-columns: 6fr 5fr;
  }
  .case.image-left .text { order: 2; }
  .case.image-left .image { order: 1; }

  .case-meta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .case-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 0.02em;
    background: var(--elevated);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 3px 11px;
  }

  .case-kicker {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .name {
    font-size: clamp(36px, 4vw, 52px);
    line-height: 1.02;
    margin: 0 0 20px;
  }

  .blurb {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 28px;
    max-width: 50ch;
  }

  .metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    margin-bottom: 28px;
  }

  .metric-v {
    font-family: var(--font-display);
    font-weight: 560;
    font-variation-settings: "SOFT" 60;
    font-size: 27px;
    line-height: 1;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }

  .metric-l {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.4;
  }

  .case-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--ink);
    text-decoration: none;
    font-weight: 500;
    font-size: 14px;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: color 160ms ease;
  }

  .case-link:hover {
    color: var(--pounamu);
  }

  .image-frame {
    aspect-ratio: 4 / 3;
    background: var(--elevated);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    position: relative;
  }

  /* Before/after comparison ---------------------------------------- */
  .compare-stack {
    position: absolute;
    inset: 0;
    --pos: 50%;
    cursor: ew-resize;
    /* Let the page still scroll vertically when the gesture starts on the
       slider, but claim horizontal drags so we can move the divider. */
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }

  .compare-layer {
    position: absolute;
    inset: 0;
    /* The stack owns all pointer interaction; let events pass through the
       layer (and its images) so a drag starting on the image still moves
       the divider instead of triggering the browser's native image-drag. */
    pointer-events: none;
  }

  .compare-layer :global(.screenshot) {
    object-fit: cover;
    /* Disable the browser's native image drag (the "ghost" preview that
       otherwise hijacks the gesture and breaks the slider). */
    -webkit-user-drag: none;
    user-select: none;
    -webkit-user-select: none;
  }

  /* Old site sits on top, revealed left of the handle */
  .compare-before {
    clip-path: inset(0 calc(100% - var(--pos)) 0 0);
  }

  /* A native range input spans the frame for keyboard + screen-reader
     support. Pointer/touch dragging is handled in JS on .compare-stack
     because styled range inputs drag unreliably on iOS Safari. */
  .compare-range {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    opacity: 0;
    pointer-events: none;
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
  }
  .compare-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 44px;
    height: 100%;
  }
  .compare-range::-moz-range-thumb {
    width: 44px;
    height: 100%;
    border: 0;
    background: transparent;
  }

  /* No visible bar — just a full-height anchor that carries the grip on the
     seam, so the two screenshots meet edge-to-edge. */
  .compare-divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--pos);
    width: 0;
    pointer-events: none;
  }

  .compare-grip {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--compare-handle);
    color: var(--compare-handle-ink);
    box-shadow: var(--compare-shadow);
    transition: transform 160ms ease;
  }

  .compare-stack:hover .compare-grip {
    transform: translate(-50%, -50%) scale(1.06);
  }

  .compare-range:focus-visible ~ .compare-divider .compare-grip {
    outline: 2px solid var(--pounamu);
    outline-offset: 3px;
  }

  .compare-label {
    position: absolute;
    top: 12px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 9px;
    border-radius: 999px;
    background: var(--compare-label-bg);
    color: var(--compare-label-ink);
    backdrop-filter: blur(2px);
    pointer-events: none;
  }
  .compare-label-before {
    left: 12px;
  }
  .compare-label-after {
    right: 12px;
  }

  @media (prefers-reduced-motion: reduce) {
    .compare-grip,
    .compare-stack:hover .compare-grip {
      transition: none;
      transform: translate(-50%, -50%);
    }
  }

  /* iPhone silhouette overlay — bottom-right of the web frame */
  .phone-overlay {
    position: absolute;
    right: 5.5%;
    bottom: 5%;
    width: 22%;
    aspect-ratio: 1206 / 2622;
    pointer-events: none;
  }

  /* Volume rocker on the left of the chassis */
  .phone-overlay::before {
    content: "";
    position: absolute;
    left: -1.6%;
    top: 22%;
    width: 1.8%;
    height: 14%;
    background: #0a0e0d;
    border-radius: 1.5px 0 0 1.5px;
  }

  /* Power button on the right of the chassis */
  .phone-overlay::after {
    content: "";
    position: absolute;
    right: -1.6%;
    top: 26%;
    width: 1.8%;
    height: 9%;
    background: #0a0e0d;
    border-radius: 0 1.5px 1.5px 0;
  }

  .phone-frame {
    position: relative;
    width: 100%;
    height: 100%;
    background: #0e1413;
    border-radius: 14% / 6.5%;
    padding: 2.5%;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.08) inset,
      0 0 0 1px rgba(255, 255, 255, 0.04) inset,
      0 18px 38px -10px rgba(14, 20, 19, 0.45),
      0 4px 10px -2px rgba(14, 20, 19, 0.25);
    overflow: hidden;
  }

  .phone-frame :global(.screenshot) {
    border-radius: 11% / 5%;
    object-fit: cover;
  }

  @media (max-width: 720px) {
    .phone-overlay {
      width: 28%;
      right: 4%;
      bottom: 4%;
    }
  }

  @media (max-width: 1024px) {
    .case {
      padding: 40px;
      gap: 40px;
    }
    .case,
    .case.image-right,
    .case.image-left {
      grid-template-columns: 1fr;
    }
    .case.image-left .text,
    .case.image-left .image { order: initial; }
  }

  @media (max-width: 720px) {
    .inner { padding: 72px var(--pad-x); }
    .case { padding: 28px; gap: 28px; }
    .metrics { grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .metric-v { font-size: 22px; }
  }
</style>

<script>
  document.querySelectorAll<HTMLAnchorElement>("a[data-case-name]").forEach((a) => {
    a.addEventListener("click", () => {
      (window as any).posthog?.capture("case_study_cta_clicked", {
        case_name: a.dataset.caseName,
      });
    });
  });

  // Before/after slider: mirror the native range value onto the --pos var
  // that clips the "before" layer and positions the handle. The range stays
  // for keyboard + screen-reader support; pointer/touch drags are handled
  // here because styled range inputs drag unreliably on iOS Safari.
  document
    .querySelectorAll<HTMLElement>(".compare-stack")
    .forEach((stack) => {
      const range = stack.querySelector<HTMLInputElement>(".compare-range");
      if (!range) return;

      const sync = () =>
        stack.style.setProperty("--pos", `${range.value}%`);
      sync();
      range.addEventListener("input", sync);

      const setFromPointer = (clientX: number) => {
        const rect = stack.getBoundingClientRect();
        if (rect.width === 0) return;
        const pct = Math.max(
          0,
          Math.min(100, ((clientX - rect.left) / rect.width) * 100),
        );
        range.value = String(pct);
        sync();
      };

      let activePointer: number | null = null;

      // Belt-and-braces: if a nested image still surfaces a dragstart
      // (some browsers fire it before pointerdown captures), kill it so
      // the native image-drag ghost can't hijack the gesture.
      stack.addEventListener("dragstart", (e) => e.preventDefault());

      stack.addEventListener("pointerdown", (e) => {
        activePointer = e.pointerId;
        stack.setPointerCapture(e.pointerId);
        // On mouse, click-to-jump matches range-input convention. On touch,
        // wait for a deliberate horizontal drag so a stray tap (or the start
        // of a vertical scroll) doesn't yank the divider.
        if (e.pointerType === "mouse") setFromPointer(e.clientX);
        range.focus({ preventScroll: true });
      });

      stack.addEventListener("pointermove", (e) => {
        if (e.pointerId !== activePointer) return;
        setFromPointer(e.clientX);
      });

      const stop = (e: PointerEvent) => {
        if (e.pointerId !== activePointer) return;
        activePointer = null;
        if (stack.hasPointerCapture(e.pointerId)) {
          stack.releasePointerCapture(e.pointerId);
        }
      };
      stack.addEventListener("pointerup", stop);
      stack.addEventListener("pointercancel", stop);
    });
</script>
