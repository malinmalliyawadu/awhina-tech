---
import Screenshot from "./Screenshot.astro";

interface Props {
  before: string;
  beforeAlt: string;
  after: string;
  afterAlt: string;
  beforeLabel?: string;
  afterLabel?: string;
  /** Starting divider position, 0–100 (% from the left). */
  start?: number;
}

const {
  before,
  beforeAlt,
  after,
  afterAlt,
  beforeLabel = "Before",
  afterLabel = "After",
  // Divider position from the left. Default leans heavily to the result —
  // ~80% "what we built" showing, a 20% sliver of the old system inviting a drag.
  start = 20,
} = Astro.props;

const pos = Math.min(100, Math.max(0, start));
const ariaLabel = `Drag to compare: ${beforeLabel} on the left, ${afterLabel} on the right`;
---

<div class="ba" style={`--pos:${pos}%`}>
  <!-- Base layer: the result -->
  <div class="ba-layer ba-after">
    <Screenshot src={after} alt={afterAlt} />
  </div>

  <!-- Overlay: the old system, clipped to the left of the divider -->
  <div class="ba-layer ba-before" aria-hidden="true">
    <Screenshot src={before} alt="" />
  </div>

  <span class="ba-label is-before">{beforeLabel}</span>
  <span class="ba-label is-after">{afterLabel}</span>

  <input
    class="ba-range"
    type="range"
    min="0"
    max="100"
    value={pos}
    step="0.1"
    autocomplete="off"
    data-start={pos}
    aria-label={ariaLabel}
  />

  <div class="ba-divider" aria-hidden="true"></div>
  <div class="ba-handle" aria-hidden="true">
    <span class="ba-grip">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M10 8l-4 4 4 4M14 8l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>

  <span class="ba-hint" aria-hidden="true">Drag to compare</span>
</div>

<style>
  .ba {
    position: absolute;
    inset: 0;
    overflow: hidden;
    isolation: isolate;
    user-select: none;
    -webkit-user-select: none;
  }

  .ba-layer {
    position: absolute;
    inset: 0;
  }

  .ba-layer :global(.screenshot) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  /* Old system sits above the result, revealed to the left of the divider */
  .ba-before {
    clip-path: inset(0 calc(100% - var(--pos)) 0 0);
  }

  .ba-label {
    position: absolute;
    top: 14px;
    z-index: 3;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.03em;
    color: var(--ink);
    background: var(--surface);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-soft);
    border-radius: 999px;
    padding: 5px 11px;
    pointer-events: none;
    white-space: nowrap;
  }

  .ba-label.is-before { left: 14px; }
  .ba-label.is-after { right: 14px; }

  /* The actual control — full-bleed, invisible, owns all interaction.
     Native range input gives keyboard, touch, and screen-reader support. */
  .ba-range {
    position: absolute;
    inset: 0;
    z-index: 4;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    background: transparent;
    appearance: none;
    -webkit-appearance: none;
    cursor: ew-resize;
    /* let vertical page scrolling through; horizontal drag controls compare */
    touch-action: pan-y;
  }

  .ba-range:focus { outline: none; }

  .ba-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 48px;
    height: 100%;
    cursor: ew-resize;
  }

  .ba-range::-moz-range-thumb {
    width: 48px;
    height: 100%;
    border: 0;
    background: transparent;
    cursor: ew-resize;
  }

  .ba-divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--pos);
    width: 2px;
    transform: translateX(-1px);
    background: var(--ink);
    z-index: 2;
    pointer-events: none;
  }

  .ba-handle {
    position: absolute;
    top: 50%;
    left: var(--pos);
    transform: translate(-50%, -50%);
    z-index: 3;
    pointer-events: none;
  }

  .ba-grip {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--surface);
    color: var(--ink);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
    transition:
      box-shadow 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .ba:hover .ba-grip {
    border-color: var(--ink);
  }

  .ba-range:focus-visible ~ .ba-handle .ba-grip {
    border-color: var(--ink);
    box-shadow:
      0 0 0 3px var(--line-strong),
      var(--shadow-card);
  }

  .ba-range:active ~ .ba-handle .ba-grip {
    transform: scale(0.94);
  }

  .ba-hint {
    position: absolute;
    left: 50%;
    bottom: 14px;
    transform: translateX(-50%);
    z-index: 3;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--surface);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-soft);
    border-radius: 999px;
    padding: 5px 12px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 240ms ease;
  }

  /* Surface the hint only when the visitor is engaging the comparison —
     on hover, or on keyboard focus of the control. */
  .ba:hover .ba-hint,
  .ba-range:focus-visible ~ .ba-hint {
    opacity: 1;
  }

  /* Once they've actually dragged it, the hint has done its job. */
  .ba.is-touched .ba-hint {
    opacity: 0;
  }

  @media (max-width: 720px) {
    .ba-label { font-size: 10px; padding: 4px 9px; }
    .ba-label.is-before { left: 10px; }
    .ba-label.is-after { right: 10px; }
    .ba-grip { width: 40px; height: 40px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ba-grip,
    .ba-hint {
      transition: none;
    }
  }
</style>

<script>
  for (const ba of document.querySelectorAll<HTMLElement>(".ba")) {
    const range = ba.querySelector<HTMLInputElement>(".ba-range");
    if (!range) continue;

    // Defeat browser form-state restoration (bfcache / Firefox) so the
    // comparison always opens at the intended split, not a stale drag.
    const start = range.dataset.start;
    if (start != null) range.value = start;

    const apply = () => ba.style.setProperty("--pos", `${range.value}%`);
    apply();

    let touched = false;
    const markTouched = () => {
      if (touched) return;
      touched = true;
      ba.classList.add("is-touched");
    };

    range.addEventListener("input", () => {
      apply();
      markTouched();
    });
    range.addEventListener("pointerdown", markTouched);
  }
</script>
