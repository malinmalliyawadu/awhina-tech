---
import FadeUp from "./FadeUp.astro";
import { PROBLEMS } from "../data/problems";

const icons: Record<string, string> = {
  "01": "M3 21V8l9-5 9 5v13M9 21V12h6v9", // building / SaaS
  "02": "M4 7h16M4 12h16M4 17h10",         // mismatched stack
  "03": "M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM14 14h6v6h-6z", // five tools
  "04": "M12 1v22M5 8c0-2 2-3 7-3s7 1 7 3-2 3-7 3-7 1-7 3 2 3 7 3 7-1 7-3", // money
};
---

<section class="problems">
  <div class="inner">
    <FadeUp>
      <div class="header">
        <span class="eyebrow">The problem</span>
        <h2 class="title">
          Most charity software is built for vendors, not for the people doing
          the work.
        </h2>
        <p class="lede">
          Funders pay for software, software companies pay their executives, and
          the volunteers running the booking sheet still end up in spreadsheets
          at 11pm.
        </p>
      </div>
    </FadeUp>

    <div class="grid">
      {
        PROBLEMS.map((p, i) => (
          <FadeUp delay={i * 60}>
            <article class="card">
              <div class="card-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d={icons[p.k]} stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="card-num">{p.k}</div>
              <h3 class="card-title">{p.t}</h3>
              <p class="card-body">{p.b}</p>
            </article>
          </FadeUp>
        ))
      }
    </div>
  </div>
</section>

<style>
  .problems {
    background: var(--surface-2);
    border-bottom: 1px solid var(--line);
  }

  .inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 112px var(--pad-x);
  }

  .header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    max-width: 760px;
    margin-bottom: 64px;
  }

  .title {
    font-size: clamp(32px, 4.2vw, 52px);
    line-height: 1.08;
    margin: 8px 0 0;
  }

  .lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--muted);
    margin: 12px 0 0;
    max-width: 60ch;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  .card {
    background: var(--elevated);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
    padding: 32px;
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto auto;
    column-gap: 16px;
    row-gap: 8px;
    align-items: start;
  }

  .card-icon {
    grid-row: 1 / 2;
    grid-column: 1 / 2;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-blob);
    background: var(--pounamu-soft);
    color: var(--pounamu);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .card-num {
    grid-row: 1 / 2;
    grid-column: 2 / 3;
    align-self: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 15px;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .card-title {
    grid-row: 2 / 3;
    grid-column: 1 / 3;
    font-size: 20px;
    line-height: 1.3;
    font-weight: 580;
    letter-spacing: -0.005em;
    margin: 8px 0 0;
  }

  .card-body {
    grid-row: 3 / 4;
    grid-column: 1 / 3;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }

  @media (max-width: 720px) {
    .inner { padding: 72px var(--pad-x); }
    .grid { grid-template-columns: 1fr; }
    .card { padding: 24px; }
  }
</style>
