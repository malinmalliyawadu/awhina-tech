---
import StatCard from "./StatCard.astro";

const MONTHS = ["Oct", "Nov", "Dec", "Jan", "Feb", "Mar"];

// Volunteer hours (scaled 0-1, mapped to chart later). Trend: rising.
const HOURS = [0.34, 0.41, 0.38, 0.55, 0.68, 0.78];
// Donors active (scaled).
const DONORS = [0.22, 0.28, 0.31, 0.42, 0.47, 0.55];

// Chart geometry
const W = 320;
const H = 140;
const PAD_L = 28;
const PAD_R = 12;
const PAD_T = 14;
const PAD_B = 26;
const innerW = W - PAD_L - PAD_R;
const innerH = H - PAD_T - PAD_B;

const xAt = (i: number) => PAD_L + (i * innerW) / (HOURS.length - 1);
const yAt = (v: number) => PAD_T + (1 - v) * innerH;

const toPath = (vals: number[]) =>
  vals.map((v, i) => `${i === 0 ? "M" : "L"}${xAt(i).toFixed(1)},${yAt(v).toFixed(1)}`).join(" ");

const toArea = (vals: number[]) =>
  `${toPath(vals)} L${xAt(vals.length - 1).toFixed(1)},${(PAD_T + innerH).toFixed(1)} L${xAt(0).toFixed(1)},${(PAD_T + innerH).toFixed(1)} Z`;

const Y_TICKS = [0, 0.5, 1];
const Y_LABELS = ["0", "800", "1.6k"];

const STAT_ICON = "M3 3v18h18 M7 14l4-4 4 4 5-5";
---

<div class="insights">
  <div class="head">
    <div>
      <div class="title">Volunteer hours</div>
      <div class="sub">Last 6 months · all programmes</div>
    </div>
    <div class="series-key">
      <span class="key"><span class="swatch sw-pounamu"></span> Hours</span>
      <span class="key"><span class="swatch sw-kowhai"></span> Donors</span>
    </div>
  </div>

  <svg
    class="chart"
    viewBox={`0 0 ${W} ${H}`}
    role="img"
    aria-label="Volunteer hours and active donors trending up over six months"
    preserveAspectRatio="none"
  >
    <!-- gridlines -->
    {Y_TICKS.map((t, i) => (
      <g>
        <line
          x1={PAD_L}
          x2={W - PAD_R}
          y1={yAt(t)}
          y2={yAt(t)}
          stroke="var(--line)"
          stroke-width="1"
          stroke-dasharray={i === 0 ? "0" : "2 3"}
        />
        <text
          x={PAD_L - 6}
          y={yAt(t) + 3}
          font-family="var(--font-mono)"
          font-size="9"
          fill="var(--muted)"
          text-anchor="end"
        >
          {Y_LABELS[i]}
        </text>
      </g>
    ))}

    <!-- area under hours -->
    <path d={toArea(HOURS)} fill="var(--pounamu)" fill-opacity="0.08" />

    <!-- donors line -->
    <path d={toPath(DONORS)} fill="none" stroke="var(--kowhai)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="3 3" />

    <!-- hours line -->
    <path d={toPath(HOURS)} fill="none" stroke="var(--pounamu)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />

    <!-- hours points -->
    {HOURS.map((v, i) => (
      <circle cx={xAt(i)} cy={yAt(v)} r={i === HOURS.length - 1 ? 3.5 : 2} fill="var(--pounamu)" />
    ))}

    <!-- last-point ring -->
    <circle cx={xAt(HOURS.length - 1)} cy={yAt(HOURS[HOURS.length - 1])} r="6" fill="none" stroke="var(--pounamu)" stroke-opacity="0.25" stroke-width="1" />

    <!-- x labels -->
    {MONTHS.map((m, i) => (
      <text
        x={xAt(i)}
        y={H - 8}
        font-family="var(--font-mono)"
        font-size="9.5"
        fill="var(--muted)"
        text-anchor="middle"
      >
        {m}
      </text>
    ))}
  </svg>

  <StatCard
    title="Hours volunteered"
    iconPath={STAT_ICON}
    stats={[
      { value: "1,576", label: "Last 6 months", accent: "pounamu" },
      { value: "+18%", label: "Year on year", accent: "ink" },
    ]}
  />
</div>

<style>
  .insights {
    display: grid;
    gap: 14px;
  }

  .head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--line);
  }

  .title {
    font-size: 15.5px;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin-bottom: 3px;
  }

  .sub {
    font-size: 11.5px;
    color: var(--muted);
  }

  .series-key {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .key {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .swatch {
    width: 12px;
    height: 2px;
    border-radius: 1px;
    display: inline-block;
  }

  .sw-pounamu { background: var(--pounamu); }
  .sw-kowhai { background: var(--kowhai); }

  .chart {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
