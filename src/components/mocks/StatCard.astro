---
interface Stat {
  value: string;
  label: string;
  accent?: "pounamu" | "kowhai" | "clay" | "ink";
}

interface Props {
  title: string;
  iconPath: string;
  stats: Stat[];
}

const { title, iconPath, stats } = Astro.props;
---

<div class="stat-card" role="presentation">
  <div class="stat-head">
    <span class="stat-icon" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
        <path d={iconPath} stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
    <span class="stat-title">{title}</span>
  </div>
  <div class:list={["stat-grid", stats.length === 4 && "stat-grid-4"]}>
    {stats.map((s) => (
      <div class="stat-item">
        <div class={`stat-value accent-${s.accent ?? "pounamu"}`}>{s.value}</div>
        <div class="stat-label">{s.label}</div>
      </div>
    ))}
  </div>
</div>

<style>
  .stat-card {
    position: absolute;
    right: -14px;
    bottom: -22px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 14px 16px;
    min-width: 200px;
    box-shadow:
      0 1px 2px rgba(14, 20, 19, 0.05),
      0 16px 36px -10px rgba(14, 20, 19, 0.22);
  }

  .stat-head {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-bottom: 10px;
    font-size: 11.5px;
    color: var(--muted);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .stat-icon {
    color: var(--pounamu);
    display: inline-flex;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(2, auto);
    gap: 12px 22px;
  }

  .stat-grid-4 {
    grid-template-columns: repeat(2, auto);
  }

  .stat-value {
    font-size: 22px;
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    margin-bottom: 4px;
  }

  .accent-pounamu { color: var(--pounamu); }
  .accent-kowhai { color: var(--kowhai); }
  .accent-clay { color: var(--clay); }
  .accent-ink { color: var(--ink); }

  .stat-label {
    font-size: 11px;
    color: var(--muted);
    line-height: 1.35;
    max-width: 14ch;
  }

  @media (max-width: 720px) {
    .stat-card {
      right: 6px;
      bottom: -16px;
      padding: 10px 12px;
      min-width: 0;
    }
    .stat-value { font-size: 18px; }
    .stat-grid { gap: 8px 14px; }
  }
</style>
