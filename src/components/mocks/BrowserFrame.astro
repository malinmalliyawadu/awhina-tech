---
interface Props {
  url?: string;
}
const { url = "example.org.nz" } = Astro.props;
---

<div class="frame">
  <div class="chrome">
    <div class="dots" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
    <div class="urlbar">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.4 1.4M17.6 17.6L19 19M5 19l1.4-1.4M17.6 6.4L19 5M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      <span class="url">{url}</span>
    </div>
    <div class="chrome-spacer" aria-hidden="true"></div>
  </div>
  <div class="canvas">
    <slot />
  </div>
</div>

<style>
  .frame {
    position: relative;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(14, 20, 19, 0.05),
      0 22px 44px -22px rgba(14, 20, 19, 0.18);
  }

  .chrome {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 10px 14px;
    background: #f6f5ef;
    border-bottom: 1px solid var(--line);
  }

  .dots {
    display: inline-flex;
    gap: 6px;
  }

  .dots span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #d6d4cc;
  }

  .urlbar {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    justify-self: center;
    max-width: 360px;
    width: 100%;
  }

  .url {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .chrome-spacer {
    width: 56px;
  }

  .canvas {
    position: relative;
    padding: 22px;
    min-height: 280px;
  }

  @media (max-width: 720px) {
    .chrome { padding: 8px 10px; gap: 8px; }
    .chrome-spacer { width: 28px; }
    .urlbar { font-size: 10px; padding: 3px 10px; }
    .canvas { padding: 16px; min-height: 240px; }
  }
</style>
