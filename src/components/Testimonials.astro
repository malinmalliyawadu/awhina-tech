---
import FadeUp from "./FadeUp.astro";

const quotes = [
  {
    q: "We were paying $480 a month across four tools that didn't talk to each other. Āwhina rebuilt the whole stack as one site for the cost of a tank of petrol.",
    a: "Operations lead",
    o: "Everybody Eats",
  },
  {
    q: "It's the first time we've worked with a tech vendor who actually understood what a koha is, and didn't try to make us run it through a credit card processor that takes a cut.",
    a: "Communications",
    o: "Compassion Soup Kitchen",
  },
];
---

<section class="testimonials">
  <div class="inner">
    <FadeUp>
      <div class="header">
        <span class="eyebrow">In their words</span>
        <h2 class="title">Said about the work.</h2>
      </div>
    </FadeUp>

    <div class="grid">
      {
        quotes.map((t, i) => (
          <FadeUp delay={i * 100}>
            <figure class="quote-card">
              <svg class="mark" width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M9 11C9 8.5 7 7 5 7M9 11v6H4V11M9 11C9 8.5 7 7 5 7M20 11C20 8.5 18 7 16 7M20 11v6h-5V11M20 11C20 8.5 18 7 16 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <blockquote class="quote">{t.q}</blockquote>
              <figcaption class="attr">
                <div class="attr-name">{t.a}</div>
                <div class="attr-org">{t.o}</div>
              </figcaption>
            </figure>
          </FadeUp>
        ))
      }
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
  }

  .inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 112px var(--pad-x);
  }

  .header {
    display: grid;
    gap: 12px;
    max-width: 720px;
    margin-bottom: 56px;
  }

  .title {
    font-size: clamp(32px, 4.2vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    font-weight: 500;
    margin: 8px 0 0;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .quote-card {
    margin: 0;
    padding: 40px;
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .mark {
    color: var(--pounamu);
    opacity: 0.9;
  }

  .quote {
    margin: 0;
    font-size: 22px;
    line-height: 1.4;
    letter-spacing: -0.012em;
    font-weight: 400;
    color: var(--ink);
  }

  .attr {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .attr-name {
    font-size: 14px;
    font-weight: 500;
  }

  .attr-org {
    font-size: 13px;
    color: var(--muted);
  }

  @media (max-width: 960px) {
    .inner { padding: 72px var(--pad-x); }
    .grid { grid-template-columns: 1fr; }
    .quote { font-size: 19px; }
    .quote-card { padding: 28px; }
  }
</style>
