---
import FadeUp from "./FadeUp.astro";

const compare = [
  { d: "Cost as you grow", saas: "Climbs with every seat, contact and add-on", awhina: "Flat $200/month, whatever your size" },
  { d: "Customisation", saas: "Limited to the vendor's settings and themes", awhina: "Bent to your workflow, your brand, your reo" },
  { d: "Integration depth", saas: "Connects only where the vendor allows — often a paid add-on", awhina: "Connects to whatever you already use" },
  { d: "The roadmap", saas: "Set by the vendor — you wait, or you pay", awhina: "Set by your charity" },
  { d: "Your data", saas: "On their servers, on their terms", awhina: "Yours — data, domain, and code" },
  { d: "If you stop paying", saas: "It's gone", awhina: "You keep what we built; we help you move" },
];
---

<section id="cost" class="cost">
  <div class="inner">
    <FadeUp>
      <div class="header">
        <span class="eyebrow">Rent or own</span>
        <h2 class="title">Rented software costs more as you grow. Owned software doesn't.</h2>
        <p class="lede">
          Most charity tools charge per seat, per contact, or a slice of every
          donation — so the bill climbs the moment your mahi grows. Software
          you own doesn't work that way.
        </p>
      </div>
    </FadeUp>

    <FadeUp delay={80}>
      <div class="table-wrap">
        <table class="compare">
          <caption class="sr-only">Rented SaaS stack compared with Āwhina, at a glance</caption>
          <thead>
            <tr>
              <th scope="col"><span class="sr-only">Dimension</span></th>
              <th scope="col">Rented SaaS stack</th>
              <th scope="col" class="col-awhina">Āwhina</th>
            </tr>
          </thead>
          <tbody>
            {compare.map((r) => (
              <tr>
                <th scope="row">{r.d}</th>
                <td>{r.saas}</td>
                <td class="col-awhina">{r.awhina}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </FadeUp>
  </div>
</section>

<style>
  .cost {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
  }

  .inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 112px var(--pad-x);
  }

  .header {
    display: grid;
    gap: 12px;
    max-width: 760px;
    margin-bottom: 48px;
  }

  .title {
    font-size: clamp(32px, 4.2vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    font-weight: 500;
    margin: 8px 0 0;
  }

  .lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--muted);
    margin: 4px 0 0;
    max-width: 62ch;
  }

  .table-wrap {
    overflow-x: auto;
  }

  .compare {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
    font-size: 14px;
  }

  .compare th,
  .compare td {
    text-align: left;
    padding: 18px 22px;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
    line-height: 1.45;
  }

  .compare thead th {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--line-strong);
  }

  .compare tbody th {
    font-weight: 600;
    color: var(--ink);
    width: 22%;
  }

  .compare td {
    color: var(--muted);
  }

  .compare .col-awhina {
    background: var(--pounamu-soft);
    color: var(--ink-2);
    font-weight: 500;
  }

  .compare thead .col-awhina {
    color: var(--pounamu);
  }

  .compare tr:last-child th,
  .compare tr:last-child td {
    border-bottom: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 1024px) {
    .inner { padding: 72px var(--pad-x); }
  }

  @media (max-width: 720px) {
    .header { margin-bottom: 32px; }
    .compare th,
    .compare td { padding: 14px 16px; }
  }
</style>
