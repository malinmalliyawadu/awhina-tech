---
import FadeUp from "./FadeUp.astro";

/*
 * Cost-over-time: an interactive, hand-built SVG (no chart lib).
 *
 * Progressive enhancement:
 *  - Server renders the full 3-year picture statically. With no JS (or
 *    reduced-motion) that complete chart + the table below IS the content.
 *  - With JS: a Year 1/2/3 stepper re-animates the SaaS curve and counts
 *    the running delta; data points reveal tooltips on hover/focus.
 *
 * Geometry (viewBox 0 0 760 348):
 *   x(month) = 64 + month * (656 / 36)        months 0‒36 across the plot
 *   y(value) = 300 − value * 0.325            $0 → y300 (baseline), up = more
 *
 * The SaaS figures are an ILLUSTRATIVE scenario built from vendors' public
 * list pricing (see .source). The only exact figure is Āwhina's flat $200.
 */
const X0 = 64;
const X1 = 720;
const xOf = (m: number) => +(X0 + m * ((X1 - X0) / 36)).toFixed(2);
const yOf = (v: number) => +(300 - v * 0.325).toFixed(2);

const AWHINA = 200;
const yA = yOf(AWHINA);

// Monthly SaaS cost — steps up each time a tool is added / seats creep.
const STEPS = [
  { m0: 0, m1: 3, cost: 30 },
  { m0: 3, m1: 9, cost: 90 },
  { m0: 9, m1: 17, cost: 260 },
  { m0: 17, m1: 27, cost: 470 },
  { m0: 27, m1: 36, cost: 640 },
];

// Stepped polyline for the SaaS line (horizontal hold, then a vertical jump).
const linePts: string[] = [];
STEPS.forEach((s, i) => {
  if (i > 0) linePts.push(`${xOf(s.m0)},${yOf(s.cost)}`); // the jump
  linePts.push(`${xOf(s.m0)},${yOf(s.cost)}`);
  linePts.push(`${xOf(s.m1)},${yOf(s.cost)}`);
});
const saasLine = linePts.join(" ");
const saasArea = `${saasLine} ${X1},300 ${X0},300`;

// Crossover: the SaaS line passes $200 on the CRM step (the jump at month 9).
const xCross = xOf(9);

// "Overspend" wedge — between the two lines, after crossover.
const wedge = [
  `${xCross},${yA}`,
  `${xCross},${yOf(260)}`,
  `${xOf(17)},${yOf(260)}`,
  `${xOf(17)},${yOf(470)}`,
  `${xOf(27)},${yOf(470)}`,
  `${xOf(27)},${yOf(640)}`,
  `${X1},${yOf(640)}`,
  `${X1},${yA}`,
].join(" ");

const gridlines = [600, 400, 200];

// Net cumulative cost vs Āwhina ($200/mo) at each horizon. Year 1 the SaaS
// stack is genuinely cheaper — that honesty is the point; it compounds.
const deltas: Record<number, number> = { 1: -990, 2: 1200, 3: 5970 };
const horizonX: Record<number, number> = {
  1: xOf(12),
  2: xOf(24),
  3: xOf(36),
};

// Focusable nodes — each carries the real tool + its public list pricing.
const nodes = [
  { m: 0, cost: 30, cat: "Website builder", price: "Squarespace · from ~US$16/mo" },
  { m: 3, cost: 90, cat: "Email marketing", price: "Mailchimp · free under 250 contacts, then ~US$17–25/mo+" },
  { m: 9, cost: 260, cat: "Nonprofit CRM", price: "Bloomerang · from US$125/mo, priced by constituents" },
  { m: 17, cost: 470, cat: "Volunteer management", price: "Priced per volunteer — climbs as kaimahi grow" },
  { m: 27, cost: 640, cat: "Donation platform", price: "Donorbox · ~2.95% + ~2.2% + $0.30 per gift" },
].map((n) => {
  const x = xOf(n.m);
  const y = yOf(n.cost);
  const PAD = 16;
  // SVG <text> can't wrap — size the box to the (estimated) widest line so
  // copy never spills out. Generous per-char estimates avoid clipping.
  const tipW = Math.min(
    380,
    Math.ceil(Math.max(n.cat.length * 7, n.price.length * 6) + PAD * 2),
  );
  const tipX = +Math.max(
    8,
    Math.min(x - tipW / 2, 760 - 8 - tipW),
  ).toFixed(2);
  return { ...n, x, y, tipX, tipW, tipPad: PAD };
});

const compare = [
  { d: "Cost as you grow", saas: "Climbs with every seat, contact and add-on", awhina: "Flat $200/month, whatever your size" },
  { d: "The roadmap", saas: "Set by the vendor — you wait, or you pay", awhina: "Set by your charity" },
  { d: "Your data", saas: "On their servers, on their terms", awhina: "Yours — data, domain, and code" },
  { d: "If you stop paying", saas: "It's gone", awhina: "You keep what we built; we help you move" },
  { d: "What you end up with", saas: "A rented tool, identical to everyone else's", awhina: "Software built for how you actually work" },
];
---

<section id="cost" class="cost">
  <div class="inner">
    <FadeUp>
      <div class="header">
        <span class="eyebrow">The maths</span>
        <h2 class="title">Rented software gets more expensive every year.</h2>
        <p class="lede">
          Every tool charges per seat, per contact, or a slice of every
          donation. Year one it can look cheaper — then a CRM lands, the list
          grows, and the bill keeps climbing. A custom system you own doesn't
          work that way.
        </p>
      </div>
    </FadeUp>

    <FadeUp delay={80}>
      <div class="panel">
        <div class="panel-top">
          <div class="readout">
            <div class="readout-l">After <span data-years>3 years</span>, the SaaS stack has cost</div>
            <div class="readout-v" data-delta>≈&nbsp;$5,970 more</div>
            <div class="readout-s">than Āwhina's flat $200/month — and the gap is still widening.</div>
          </div>
          <div
            class="stepper"
            role="radiogroup"
            aria-label="Show the running cost after"
            data-stepper
            hidden
          >
            {[1, 2, 3].map((yr) => (
              <button
                type="button"
                role="radio"
                class:list={["step-btn", yr === 3 && "is-on"]}
                aria-checked={yr === 3 ? "true" : "false"}
                tabindex={yr === 3 ? 0 : -1}
                data-year={yr}
              >
                {yr} year{yr > 1 ? "s" : ""}
              </button>
            ))}
          </div>
        </div>

        <figure class="chart-fig">
          <p id="cost-chart-desc" class="sr-only">
            Monthly cost over time: a SaaS stack versus Āwhina. A typical
            charity's SaaS stack starts around $30 a month and steps up as
            tools, contacts and volunteers grow, passing $200 a month when a
            CRM is added and reaching roughly $640 by year three. Āwhina stays
            flat at $200 a month throughout. Year one the SaaS stack is about
            $990 cheaper overall; by year three it has cost about $5,970 more.
          </p>
          <svg
            class="chart"
            viewBox="0 0 760 348"
            role="img"
            aria-label="Monthly cost over time: a SaaS stack versus Āwhina"
            aria-describedby="cost-chart-desc"
            preserveAspectRatio="xMidYMid meet"
          >
            <defs>
              <linearGradient id="saasFill" x1="0" y1="0" x2="0" y2="1">
                <stop class="sf-0" offset="0%" />
                <stop class="sf-1" offset="100%" />
              </linearGradient>
              <linearGradient id="wedgeFill" x1="0" y1="0" x2="0" y2="1">
                <stop class="wf-0" offset="0%" />
                <stop class="wf-1" offset="100%" />
              </linearGradient>
              <pattern id="wedgeHatch" width="7" height="7" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
                <line class="hatch" x1="0" y1="0" x2="0" y2="7" />
              </pattern>
              <clipPath id="revealClip">
                <rect data-clip x="0" y="0" width="760" height="348" />
              </clipPath>
            </defs>

            {gridlines.map((g) => (
              <g class="grid">
                <line x1={X0} x2={X1} y1={yOf(g)} y2={yOf(g)} />
                <text x={X0 - 8} y={yOf(g) + 3} class="axis-y">${g}</text>
              </g>
            ))}
            <line class="grid baseline" x1={X0} x2={X1} y1="300" y2="300" />

            <g clip-path="url(#revealClip)">
              <polygon class="saas-area" points={saasArea} />
              <polygon class="wedge" points={wedge} />
              <polygon class="wedge-tex" points={wedge} />
              <polyline class="line-saas" points={saasLine} />
            </g>

            <line class="line-awhina" x1={X0} x2={X1} y1={yA} y2={yA} />

            <g class="cross" data-cross>
              <circle cx={xCross} cy={yA} r="4.5" />
              <text x={xCross + 8} y={yA - 9} class="cross-label">CRM added — past $200</text>
            </g>

            <text class="end-saas" x={X1} y={yOf(640) - 12}>Your SaaS stack</text>
            <text class="end-awhina" x={X1} y={yA + 18}>Āwhina — $200 flat</text>

            <text class="axis-x" x={X0} y="328" style="text-anchor:start">Today</text>
            {[1, 2, 3].map((yr) => (
              <text class="axis-x" x={horizonX[yr]} y="328">Year {yr}</text>
            ))}

            <g class="nodes" data-nodes>
              <g class="node-dots">
                {nodes.map((n, i) => (
                  <g
                    class:list={["node", `nd-${i}`]}
                    data-node-x={n.x}
                    style={`--ni:${i}`}
                    role="button"
                    tabindex="0"
                    aria-label={`${n.cat}: ${n.price}. Monthly cost now about $${n.cost}.`}
                  >
                    <circle class="node-hit" cx={n.x} cy={n.y} r="14" />
                    <circle class="node-dot" cx={n.x} cy={n.y} r="4" />
                  </g>
                ))}
              </g>
              <g class="node-tips" aria-hidden="true">
                {nodes.map((n, i) => (
                  <g class:list={["tip", `nt-${i}`]}>
                    <rect class="tip-box" x={n.tipX} y={n.y - 60} width={n.tipW} height="44" rx="8" />
                    <text class="tip-cat" x={n.tipX + n.tipPad} y={n.y - 39}>{n.cat}</text>
                    <text class="tip-price" x={n.tipX + n.tipPad} y={n.y - 24}>{n.price}</text>
                  </g>
                ))}
              </g>
            </g>
          </svg>
          <figcaption class="source">
            Illustrative scenario from vendors' public list pricing (approx,
            mid&#8209;2026; nonprofit discounts vary). Āwhina's $200/month is
            flat and real. Hover or focus a point for the tool behind each step.
          </figcaption>
        </figure>
      </div>
    </FadeUp>

    <FadeUp delay={140}>
      <div class="table-wrap">
        <table class="compare">
          <caption class="sr-only">Rented SaaS stack compared with Āwhina, at a glance</caption>
          <thead>
            <tr>
              <th scope="col"><span class="sr-only">Dimension</span></th>
              <th scope="col">Rented SaaS stack</th>
              <th scope="col" class="col-awhina">Āwhina</th>
            </tr>
          </thead>
          <tbody>
            {compare.map((r) => (
              <tr>
                <th scope="row">{r.d}</th>
                <td>{r.saas}</td>
                <td class="col-awhina">{r.awhina}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </FadeUp>
  </div>
</section>

<style>
  .cost {
    background:
      radial-gradient(70% 90% at 50% 0%, rgba(176, 74, 31, 0.06), transparent 70%),
      var(--surface);
    border-bottom: 1px solid var(--line);
  }

  .inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 112px var(--pad-x);
  }

  .header {
    display: grid;
    gap: 12px;
    max-width: 760px;
    margin-bottom: 48px;
  }

  .title {
    font-size: clamp(32px, 4.2vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.028em;
    font-weight: 500;
    margin: 8px 0 0;
  }

  .lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--muted);
    margin: 4px 0 0;
    max-width: 62ch;
  }

  .panel {
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    padding: 32px 36px 28px;
  }

  .panel-top {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px 32px;
    margin-bottom: 8px;
  }

  .readout-l {
    font-size: 13px;
    color: var(--muted);
    font-weight: 500;
  }
  .readout-l [data-years] {
    color: var(--ink-2);
  }
  .readout-v {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 4px 0 6px;
    font-variant-numeric: tabular-nums;
    color: var(--clay);
    transition: color 200ms ease;
  }
  .readout-v.is-less {
    color: var(--pounamu);
  }
  .readout-s {
    font-size: 13px;
    color: var(--muted);
    max-width: 42ch;
  }

  /* segmented year stepper */
  .stepper {
    display: inline-flex;
    padding: 4px;
    gap: 2px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
  }
  .step-btn {
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--muted);
    font: inherit;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: -0.005em;
    padding: 7px 16px;
    border-radius: 999px;
    cursor: pointer;
    transition: background 180ms ease, color 180ms ease;
  }
  .step-btn:hover {
    color: var(--ink);
  }
  .step-btn.is-on {
    background: var(--ink);
    color: var(--surface);
  }
  .step-btn:focus-visible {
    outline: 2px solid var(--pounamu);
    outline-offset: 2px;
  }

  .chart-fig {
    margin: 0;
  }
  .chart {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .grid line {
    stroke: var(--line);
    stroke-width: 1;
  }
  .grid.baseline {
    stroke: var(--line-strong);
    opacity: 0.4;
  }
  .axis-y {
    fill: var(--muted);
    font-family: var(--font-mono);
    font-size: 10px;
    text-anchor: end;
  }
  .axis-x {
    fill: var(--muted);
    font-size: 11px;
    font-weight: 500;
    text-anchor: middle;
  }

  .sf-0 { stop-color: var(--clay); stop-opacity: 0.26; }
  .sf-1 { stop-color: var(--clay); stop-opacity: 0; }
  .wf-0 { stop-color: var(--clay); stop-opacity: 0.34; }
  .wf-1 { stop-color: var(--clay); stop-opacity: 0.08; }
  .hatch { stroke: var(--clay); stroke-width: 1; opacity: 0.16; }

  .saas-area { fill: url(#saasFill); }
  .wedge { fill: url(#wedgeFill); }
  .wedge-tex { fill: url(#wedgeHatch); }

  .line-saas {
    fill: none;
    stroke: var(--clay);
    stroke-width: 3;
    stroke-linejoin: round;
    stroke-linecap: round;
  }
  .line-awhina {
    stroke: var(--pounamu);
    stroke-width: 2.5;
    stroke-linecap: round;
    filter: drop-shadow(0 0 3px var(--pounamu));
  }

  .cross circle {
    fill: var(--surface);
    stroke: var(--ink);
    stroke-width: 1.5;
  }
  .cross-label {
    fill: var(--ink-2);
    font-size: 10.5px;
    font-weight: 600;
    text-anchor: start;
  }

  .end-saas {
    fill: var(--clay);
    font-size: 12px;
    font-weight: 600;
    text-anchor: end;
  }
  .end-awhina {
    fill: var(--pounamu);
    font-size: 12px;
    font-weight: 600;
    text-anchor: end;
  }

  /* data point nodes + tooltips */
  .node-hit {
    fill: transparent;
    cursor: pointer;
  }
  .node-dot {
    fill: var(--surface);
    stroke: var(--clay);
    stroke-width: 2.5;
    transition: transform 160ms ease;
    transform-box: fill-box;
    transform-origin: center;
  }
  .node:hover .node-dot,
  .node:focus-visible .node-dot {
    transform: scale(1.35);
  }
  .node:focus-visible {
    outline: none;
  }
  .node:focus-visible .node-dot {
    stroke: var(--ink);
  }
  .tip {
    opacity: 0;
    pointer-events: none;
    transition: opacity 160ms ease;
  }
  .nodes:has(.nd-0:hover) .nt-0,
  .nodes:has(.nd-0:focus-visible) .nt-0,
  .nodes:has(.nd-1:hover) .nt-1,
  .nodes:has(.nd-1:focus-visible) .nt-1,
  .nodes:has(.nd-2:hover) .nt-2,
  .nodes:has(.nd-2:focus-visible) .nt-2,
  .nodes:has(.nd-3:hover) .nt-3,
  .nodes:has(.nd-3:focus-visible) .nt-3,
  .nodes:has(.nd-4:hover) .nt-4,
  .nodes:has(.nd-4:focus-visible) .nt-4 {
    opacity: 1;
  }
  .tip-box {
    fill: var(--elevated);
    stroke: var(--line);
    stroke-width: 1;
    filter: drop-shadow(0 6px 16px rgba(14, 20, 19, 0.16));
  }
  .tip-cat {
    fill: var(--ink);
    font-size: 12px;
    font-weight: 600;
  }
  .tip-price {
    fill: var(--muted);
    font-size: 11px;
  }

  .source {
    margin: 18px 0 0;
    font-size: 12px;
    line-height: 1.5;
    color: var(--muted);
    max-width: 74ch;
  }

  .table-wrap {
    margin-top: 32px;
    overflow-x: auto;
  }
  .compare {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
    font-size: 14px;
  }
  .compare th,
  .compare td {
    text-align: left;
    padding: 16px 20px;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
    line-height: 1.45;
  }
  .compare thead th {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--line-strong);
  }
  .compare tbody th {
    font-weight: 600;
    color: var(--ink);
    width: 22%;
  }
  .compare td {
    color: var(--muted);
  }
  .compare .col-awhina {
    background: var(--pounamu-soft);
    color: var(--ink-2);
    font-weight: 500;
  }
  .compare thead .col-awhina {
    color: var(--pounamu);
  }
  .compare tr:last-child th,
  .compare tr:last-child td {
    border-bottom: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* entrance: lines + nodes draw in once in view (JS adds .is-live) */
  .chart .line-saas,
  .chart .saas-area,
  .chart .wedge,
  .chart .wedge-tex {
    opacity: 0;
  }
  .chart.is-live .saas-area,
  .chart.is-live .wedge,
  .chart.is-live .wedge-tex,
  .chart.is-live .line-saas {
    opacity: 1;
    transition: opacity 500ms ease;
  }
  .chart .node {
    opacity: 0;
  }
  .chart.is-live .node {
    opacity: 1;
    transition: opacity 280ms ease;
    transition-delay: calc(420ms + var(--ni) * 90ms);
  }
  /* no-JS / static fallback: everything visible immediately */
  .chart:not(.is-armed) .line-saas,
  .chart:not(.is-armed) .saas-area,
  .chart:not(.is-armed) .wedge,
  .chart:not(.is-armed) .wedge-tex,
  .chart:not(.is-armed) .node {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .chart .line-saas,
    .chart .saas-area,
    .chart .wedge,
    .chart .wedge-tex,
    .chart .node,
    .chart.is-armed .line-saas,
    .chart.is-armed .saas-area,
    .chart.is-armed .wedge,
    .chart.is-armed .wedge-tex,
    .chart.is-armed .node {
      opacity: 1 !important;
      transition: none !important;
    }
    .node-dot {
      transition: none;
    }
  }

  @media (max-width: 1024px) {
    .inner { padding: 72px var(--pad-x); }
  }
  @media (max-width: 720px) {
    .panel { padding: 22px 18px 20px; }
    .panel-top { gap: 16px; }
    .axis-x,
    .end-saas,
    .end-awhina,
    .cross-label { font-size: 13px; }
    .tip-cat { font-size: 14px; }
    .tip-price { font-size: 12.5px; }
  }
</style>

<script>
  type Chart = SVGSVGElement & { _t?: number };

  const root = document.querySelector<HTMLElement>("#cost");
  const svg = root?.querySelector<Chart>(".chart");
  const clip = root?.querySelector<SVGRectElement>("[data-clip]");
  const stepper = root?.querySelector<HTMLElement>("[data-stepper]");
  const deltaEl = root?.querySelector<HTMLElement>("[data-delta]");
  const yearsEl = root?.querySelector<HTMLElement>("[data-years]");
  const readoutV = root?.querySelector<HTMLElement>(".readout-v");
  const nodeWraps = Array.from(
    root?.querySelectorAll<SVGGElement>(".node-dots .node") ?? [],
  );

  if (root && svg && clip && stepper && deltaEl && yearsEl && readoutV) {
    const X0 = 64;
    const FULL_W = 760;
    const horizonX: Record<number, number> = {
      1: +(X0 + 12 * (656 / 36)).toFixed(2),
      2: +(X0 + 24 * (656 / 36)).toFixed(2),
      3: 720,
    };
    const deltas: Record<number, number> = { 1: -990, 2: 1200, 3: 5970 };
    const btns = Array.from(
      stepper.querySelectorAll<HTMLButtonElement>(".step-btn"),
    );
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    stepper.hidden = false;
    svg.classList.add("is-armed");

    const fmt = (v: number) => {
      const a = Math.round(Math.abs(v) / 10) * 10;
      const s = "$" + a.toLocaleString("en-NZ");
      return v < 0 ? `≈ ${s} less` : `≈ ${s} more`;
    };

    const paint = (clipW: number, delta: number) => {
      clip.setAttribute("width", String(clipW));
      for (const w of nodeWraps) {
        const nx = parseFloat(w.dataset.nodeX ?? "0");
        w.style.visibility = nx <= clipW + 0.5 ? "visible" : "hidden";
      }
      deltaEl.textContent = fmt(delta);
      readoutV.classList.toggle("is-less", delta < 0);
    };

    let raf = 0;
    const tween = (toW: number, toD: number, fromW: number, fromD: number) => {
      cancelAnimationFrame(raf);
      if (reduce) {
        paint(toW, toD);
        return;
      }
      const dur = 700;
      const t0 = performance.now();
      const ease = (p: number) => 1 - Math.pow(1 - p, 3);
      const frame = (now: number) => {
        const p = Math.min(1, (now - t0) / dur);
        const e = ease(p);
        paint(fromW + (toW - fromW) * e, Math.round(fromD + (toD - fromD) * e));
        if (p < 1) raf = requestAnimationFrame(frame);
      };
      raf = requestAnimationFrame(frame);
    };

    let current = 3;
    let revealed = false;

    const select = (year: number, animate = true) => {
      const fromW = revealed ? horizonX[current] : X0;
      const fromD = revealed ? deltas[current] : 0;
      current = year;
      for (const b of btns) {
        const on = Number(b.dataset.year) === year;
        b.classList.toggle("is-on", on);
        b.setAttribute("aria-checked", on ? "true" : "false");
        b.tabIndex = on ? 0 : -1;
      }
      yearsEl.textContent = `${year} year${year > 1 ? "s" : ""}`;
      if (animate) tween(horizonX[year], deltas[year], fromW, fromD);
      else paint(horizonX[year], deltas[year]);
    };

    // Start hidden; reveal (draw-in + count-up) once scrolled into view.
    if (!reduce) paint(X0, 0);
    else paint(horizonX[3], deltas[3]);

    const io = new IntersectionObserver(
      (entries) => {
        for (const en of entries) {
          if (en.isIntersecting && !revealed) {
            revealed = true;
            svg.classList.add("is-live");
            select(3, !reduce);
            io.disconnect();
          }
        }
      },
      { threshold: 0.35 },
    );
    io.observe(svg);

    btns.forEach((b, i) => {
      b.addEventListener("click", () => {
        revealed = true;
        svg.classList.add("is-live");
        select(Number(b.dataset.year));
        (window as any).posthog?.capture("cost_year_selected", {
          year: Number(b.dataset.year),
        });
      });
      b.addEventListener("keydown", (e) => {
        let t = -1;
        if (e.key === "ArrowRight" || e.key === "ArrowDown")
          t = (i + 1) % btns.length;
        else if (e.key === "ArrowLeft" || e.key === "ArrowUp")
          t = (i - 1 + btns.length) % btns.length;
        if (t >= 0) {
          e.preventDefault();
          revealed = true;
          svg.classList.add("is-live");
          select(Number(btns[t].dataset.year));
          btns[t].focus();
        }
      });
    });
  }
</script>
