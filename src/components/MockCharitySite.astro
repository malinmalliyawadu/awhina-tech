---
import type { CharityScheme } from "../data/cases";

interface Props {
  scheme?: CharityScheme;
  brand?: string;
  kicker?: string;
  headline?: string;
  body?: string;
  nav?: string[];
  primaryCta?: string;
  secondaryCta?: string;
  tiles?: { value: string; label: string }[];
}

const {
  scheme = "warm",
  brand = "Everybody Eats",
  kicker = "Pay-as-you-feel dining",
  headline = "A restaurant where every plate is shared.",
  body = "Three-course meals, restaurant-quality, pay what feels right. Tāmaki Makaurau & Te Whanganui-a-Tara.",
  nav = ["About", "Our kai", "Volunteer", "Donate"],
  primaryCta = "Book a table",
  secondaryCta = "Volunteer",
  tiles = [
    { value: "12,400", label: "meals served this month" },
    { value: "2", label: "locations open" },
    { value: "37", label: "shifts this week" },
  ],
} = Astro.props;
---

<div class={`mock mock-${scheme}`}>
  <div class="mock-nav">
    <div class="mock-brand">
      <span class="mock-logo" aria-hidden="true"></span>
      {brand}
    </div>
    <div class="mock-links">
      {nav.map((n) => <span>{n}</span>)}
    </div>
    <div class="mock-cta">{primaryCta}</div>
  </div>

  <div class="mock-hero">
    <div class="mock-text">
      <div class="mock-kicker">{kicker}</div>
      <h1 class="mock-headline">{headline}</h1>
      <p class="mock-body">{body}</p>
      <div class="mock-ctas">
        <div class="mock-cta-primary">{primaryCta}</div>
        <div class="mock-cta-secondary">{secondaryCta} →</div>
      </div>
    </div>
    <div class="mock-image" aria-hidden="true">
      <div class="mock-image-card">
        <div class="mock-image-row">
          <span class="mock-image-dot"></span>
          <span class="mock-image-bar w70"></span>
        </div>
        <div class="mock-image-row">
          <span class="mock-image-dot soft"></span>
          <span class="mock-image-bar w50"></span>
        </div>
        <div class="mock-image-row">
          <span class="mock-image-dot soft"></span>
          <span class="mock-image-bar w60"></span>
        </div>
      </div>
    </div>
  </div>

  <div class="mock-tiles">
    {
      tiles.map((t) => (
        <div class="mock-tile">
          <div class="mock-tile-v">{t.value}</div>
          <div class="mock-tile-l">{t.label}</div>
        </div>
      ))
    }
  </div>
</div>

<style>
  .mock {
    --bg: #ffffff;
    --bg-soft: #fbf8f1;
    --ink: #1a1916;
    --ink-soft: #6b6a65;
    --accent: #b04a1f;
    --line: #ece8de;

    width: 100%;
    height: 100%;
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font-sans);
    display: flex;
    flex-direction: column;
  }

  .mock-forest {
    --bg: #ffffff;
    --bg-soft: #f4f7ef;
    --ink: #15201a;
    --ink-soft: #5a6a5e;
    --accent: #2f5d3a;
    --line: #e2e8da;
  }

  .mock-sea {
    --bg: #ffffff;
    --bg-soft: #eef3f3;
    --ink: #14201e;
    --ink-soft: #57676a;
    --accent: #2c5e6b;
    --line: #d9e3e2;
  }

  .mock-nav {
    padding: 12px 22px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
    border-bottom: 1px solid var(--line);
  }

  .mock-brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: -0.012em;
  }

  .mock-logo {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    background: var(--accent);
  }

  .mock-links {
    justify-self: center;
    display: flex;
    gap: 14px;
    font-size: 11px;
    color: var(--ink-soft);
  }

  .mock-cta {
    font-size: 11px;
    font-weight: 500;
    background: var(--ink);
    color: var(--bg);
    padding: 6px 11px;
    border-radius: 999px;
  }

  .mock-hero {
    padding: 26px 22px 18px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 20px;
    align-items: center;
  }

  .mock-kicker {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-bottom: 10px;
  }

  .mock-kicker::before {
    content: "";
    width: 14px;
    height: 1px;
    background: currentColor;
  }

  .mock-headline {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 24px;
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin: 0 0 10px;
  }

  .mock-body {
    font-size: 11px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 14px;
  }

  .mock-ctas {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .mock-cta-primary {
    background: var(--ink);
    color: var(--bg);
    padding: 7px 12px;
    border-radius: 6px;
    font-size: 10px;
    font-weight: 500;
  }

  .mock-cta-secondary {
    color: var(--ink);
    padding: 7px 8px;
    font-size: 10px;
    font-weight: 500;
  }

  .mock-image {
    aspect-ratio: 4 / 5;
    background: var(--bg-soft);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 12px;
    display: flex;
    align-items: flex-end;
  }

  .mock-image-card {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mock-image-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .mock-image-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .mock-image-dot.soft {
    background: var(--line);
  }

  .mock-image-bar {
    height: 6px;
    border-radius: 3px;
    background: var(--line);
    flex: 1;
  }

  .w70 { max-width: 70%; }
  .w60 { max-width: 60%; }
  .w50 { max-width: 50%; }

  .mock-tiles {
    padding: 8px 22px 22px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
  }

  .mock-tile {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 10px;
    line-height: 1.3;
    background: var(--bg);
  }

  .mock-tile-v {
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }

  .mock-tile-l {
    color: var(--ink-soft);
    font-size: 9px;
    line-height: 1.3;
  }
</style>
