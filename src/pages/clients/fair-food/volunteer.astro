                      stroke-width="1.7"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </span>
                Need a hand?
              </h2>
              <p class="support-copy">
                Anything not working, or a change you'd like — get in touch and
                we'll sort it.
              </p>
              <p class="signoff">
