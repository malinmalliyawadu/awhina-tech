                <span>{client.support.org} — {client.support.location}</span>
              </p>
            </section>
          </FadeUp>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Base>

<script>
  // TOC progressive enhancement. Both jobs fail-safe — the anchors and the
  // native <details> work with no JS at all:
  //  1. Keep the rail expanded on desktop even if a narrow-screen visitor
  //     collapsed it before resizing up (on desktop the summary is
  //     pointer-events:none, so it can't be reopened by click).
  //  2. Scrollspy: mark the section currently in view in the table of contents.
  const toc = document.querySelector<HTMLDetailsElement>(".toc");
  if (toc) {
    const desktop = window.matchMedia("(min-width: 1025px)");
    const syncOpen = () => {
      if (desktop.matches) toc.open = true;
    };
    syncOpen();
    desktop.addEventListener("change", syncOpen);
  }

  const targets = Array.from(
    document.querySelectorAll<HTMLAnchorElement>(".toc-nav a"),
  )
    .map((a) => {
      const el = document.getElementById(a.hash.slice(1));
      return el ? { a, el } : null;
    })
    .filter((t): t is { a: HTMLAnchorElement; el: HTMLElement } => t !== null);

  if (targets.length) {
    let current: HTMLAnchorElement | null = null;
    let ticking = false;

    const update = () => {
      ticking = false;
      let active = targets[0].a;
      for (const { a, el } of targets) {
        if (el.getBoundingClientRect().top - 120 <= 0) active = a;
      }
      if (
        window.innerHeight + window.scrollY >=
        document.documentElement.scrollHeight - 4
      ) {
        active = targets[targets.length - 1].a;
      }
      if (active !== current) {
        current?.removeAttribute("aria-current");
        active.setAttribute("aria-current", "true");
        current = active;
      }
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    update();
  }
</script>

