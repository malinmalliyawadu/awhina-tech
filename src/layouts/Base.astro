---
import "../styles/global.css";
import PostHog from "../components/posthog.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Āwhina Tech — Custom websites & apps for Aotearoa's charities",
  description = "We build custom websites and apps for Aotearoa's charities. $200 NZD a month, all-in. Hosting and ongoing support included.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL("/og.png", Astro.site).toString();

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Āwhina Tech",
  alternateName: "Awhina Tech",
  url: Astro.site?.toString(),
  logo: new URL("/favicon.svg", Astro.site).toString(),
  description,
  email: "kia.ora@awhinatech.nz",
  areaServed: { "@type": "Country", name: "New Zealand" },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Wellington",
    addressRegion: "Te Whanganui-a-Tara",
    addressCountry: "NZ",
  },
};
---

<!doctype html>
<html lang="en-NZ">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <script is:inline>
      // Resolve theme before first paint — avoids a light/dark flash.
      // Defines window.__setTheme / window.__currentTheme for the toggle.
      (function () {
        var d = document.documentElement;
        function setMeta(t) {
          var m = document.getElementById("theme-color");
          if (!m) {
            m = document.createElement("meta");
            m.name = "theme-color";
            m.id = "theme-color";
            document.head.appendChild(m);
          }
          m.setAttribute("content", t === "dark" ? "#181310" : "#faf5ec");
        }
        function system() {
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }
        function resolve() {
          try {
            return localStorage.getItem("theme") || system();
          } catch (e) {
            return system();
          }
        }
        function apply(t, persist) {
          d.dataset.theme = t;
          setMeta(t);
          if (persist) {
            try {
              localStorage.setItem("theme", t);
            } catch (e) {}
          }
        }
        window.__currentTheme = function () {
          return d.dataset.theme;
        };
        window.__setTheme = function (t) {
          var reduce = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
          ).matches;
          if (!reduce) {
            d.classList.add("theme-anim");
            window.setTimeout(function () {
              d.classList.remove("theme-anim");
            }, 340);
          }
          apply(t, true);
          window.dispatchEvent(
            new CustomEvent("themechange", { detail: t }),
          );
        };
        apply(resolve(), false);
      })();
    </script>

    <meta name="description" content={description} />
    <meta
      name="theme-color"
      content="#faf5ec"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#181310"
      media="(prefers-color-scheme: dark)"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Āwhina Tech" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_NZ" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    <PostHog />
  </head>
  <body>
    <slot />

    <script>
      // Scroll-triggered fade-up — one-shot per element.
      const els = document.querySelectorAll<HTMLElement>(".fade-up");
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const el = entry.target as HTMLElement;
            const delay = Number(el.dataset.delay ?? 0);
            window.setTimeout(() => el.classList.add("is-visible"), delay);
            io.unobserve(el);
          }
        },
        { threshold: 0.15 },
      );
      els.forEach((el) => io.observe(el));
    </script>
  </body>
</html>
